// RUN: not ptoas %s 2>&1 | FileCheck %s

// A count of 1 is below the multi-buffer minimum (2). The verifier should
// reject this during type construction.

module {
  func.func @bad_count_one() {
    %mb = pto.alloc_multi_tile
        : !pto.multi_tile_buf<vec, 16x16xf16, count=1>
    return
  }
}

// CHECK: multi_tile_buf count must be >= 2
