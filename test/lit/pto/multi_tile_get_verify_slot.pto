// RUN: not ptoas %s 2>&1 | FileCheck %s

// multi_tile_get with a constant slot >= count must be rejected.

module {
  func.func @bad_const_slot_out_of_range() {
    %c5 = arith.constant 5 : index
    %mb = pto.alloc_multi_tile
        : !pto.multi_tile_buf<vec, 16x16xf16, count=2>
    %s = pto.multi_tile_get %mb[%c5]
        : !pto.multi_tile_buf<vec, 16x16xf16, count=2>
       -> !pto.tile_buf<vec, 16x16xf16>
    return
  }
}

// CHECK: constant slot 5 is out of range for multi_tile_buf count=2
