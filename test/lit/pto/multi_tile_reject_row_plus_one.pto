// RUN: not ptoas --pto-arch=a3 --pto-level=level3 %s 2>&1 | FileCheck %s
// RUN: not ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s

// A `row_plus_one` (compact=2) slot layout inflates the major stride by one
// element per row (16x16xf16 -> rowStride=17 -> footprint 542 bytes), while
// multi-buffer slots are placed at product(shape)*elem_size = 512-byte
// intervals. Adjacent slots would silently overlap, so the verifier must
// reject the alloc regardless of build level.

module {
  func.func @mb_row_plus_one(%base : i64) attributes {pto.entry} {
    %mb = pto.alloc_multi_tile addr = %base
        : !pto.multi_tile_buf<!pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0, compact=2>, count=2>
    return
  }
}

// CHECK: row_plus_one compaction, whose padded storage footprint exceeds product(shape) and would overlap adjacent multi-buffer slots
