// RUN: ptoas --enable-graph-sync-solver --graph-sync-solver-event-id-max=8 --mlir-print-ir-after=pto-graph-sync-solver %s 2>&1 1>/dev/null | FileCheck %s

// Regression guard for the GSS dyn-event-id slot-binding fix.
//
// The `tadd` *reads* multi-buffer A (rotating at phase (i+1)%2) and *writes*
// multi-buffer B (rotating at phase i%2). B carries the cross-iteration WAR
// hazard (tstore reads B[i%2]; the next-but-one iteration's tadd overwrites
// the same physical slot), so GSS allocates N=2 dyn event ids for it.
//
// Because the producing `tadd` touches *two* multi-buffers at different
// phases, the dyn event lane for B's hazard must be keyed off B's slot
// (i%2), NOT the tadd's first read operand A (which is (i+1)%2). The earlier
// code grabbed the op's first slot_marker memref and would have keyed the
// wait off A's slot -- selecting the wrong event lane and letting the real
// cross-iter dependency on B through.

module {
  func.func @two_mb(%gm : memref<16x16xf16, #pto.address_space<gm>>,
                    %dst : memref<16x16xf16, #pto.address_space<gm>>,
                    %n : index) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index

    %mbA = pto.alloc_multi_tile : !pto.multi_tile_buf<vec, 16x16xf16, count=2>
    %mbB = pto.alloc_multi_tile : !pto.multi_tile_buf<vec, 16x16xf16, count=2>

    scf.for %i = %c0 to %n step %c1 {
      %iA = arith.addi %i, %c1 : index
      %idxA = arith.remui %iA, %c2 : index
      %idxB = arith.remui %i, %c2 : index

      %sA = pto.multi_tile_get %mbA[%idxA]
          : !pto.multi_tile_buf<vec, 16x16xf16, count=2>
         -> !pto.tile_buf<vec, 16x16xf16>
      %sB = pto.multi_tile_get %mbB[%idxB]
          : !pto.multi_tile_buf<vec, 16x16xf16, count=2>
         -> !pto.tile_buf<vec, 16x16xf16>

      pto.tload ins(%gm : memref<16x16xf16, #pto.address_space<gm>>)
                outs(%sA : !pto.tile_buf<vec, 16x16xf16>)
      pto.tadd ins(%sA, %sA : !pto.tile_buf<vec, 16x16xf16>,
                              !pto.tile_buf<vec, 16x16xf16>)
               outs(%sB : !pto.tile_buf<vec, 16x16xf16>)
      pto.tstore ins(%sB : !pto.tile_buf<vec, 16x16xf16>)
                 outs(%dst : memref<16x16xf16, #pto.address_space<gm>>)
    }
    return
  }
}

// CHECK-LABEL: func.func @two_mb
// CHECK:       scf.for %[[IV:.*]] = %c0 to %arg2 step %c1
// CHECK:       %[[IADD:.*]] = arith.addi %[[IV]], %c1
// idxA = (i+1)%2 -> buffer A (the tadd's read operand).
// CHECK:       %[[IDXA:.*]] = arith.remui %[[IADD]],
// idxB = i%2 -> buffer B (the tadd's write, the cross-iter hazard).
// CHECK:       %[[IDXB:.*]] = arith.remui %[[IV]],
// The tadd's WAR wait (MTE3 -> V) must select its event lane from B's slot
// (idxB), proving the dyn event id is bound to the hazard buffer and not to
// the op's first read operand A.
// CHECK:       arith.remui %[[IDXB]],
// CHECK:       %[[SEL:.*]] = arith.select
// CHECK:       pto.wait_flag_dyn[<PIPE_MTE3>, <PIPE_V>, %[[SEL]]]
// CHECK:       pto.tadd
