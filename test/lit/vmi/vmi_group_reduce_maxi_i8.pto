// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

module {
  func.func @group_reduce_maxi_i8(
      %source: !pto.vmi.vreg<256xi8>,
      %mask: !pto.vmi.mask<256xpred>) {
    %max = pto.vmi.group_reduce_maxi %source, %mask {num_groups = 8}
        : !pto.vmi.vreg<256xi8>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xi8>
    return
  }
}

// CHECK-LABEL: func.func @group_reduce_maxi_i8(
// CHECK: pto.vcgmax {{.*}} : !pto.vreg<256xi8>, !pto.mask<b8> -> !pto.vreg<256xi8>
