// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @f16_store_prefers_lane_stride(
      %src0: !pto.ptr<f16, ub>, %src1: !pto.ptr<f16, ub>,
      %dst: !pto.ptr<f16, ub>, %off: index) {
    %x = pto.vmi.load %src0[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16>
    %y = pto.vmi.load %src1[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16>
    %sum = pto.vmi.addf %x, %y
        : !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>
        -> !pto.vmi.vreg<64xf16>
    pto.vmi.store %sum, %dst[%off]
        : !pto.vmi.vreg<64xf16>, !pto.ptr<f16, ub>
    return
  }

  func.func @f16_masked_store_prefers_lane_stride(
      %src0: !pto.ptr<f16, ub>, %src1: !pto.ptr<f16, ub>,
      %dst: !pto.ptr<f16, ub>, %off: index) {
    %c32 = arith.constant 32 : index
    %mask = pto.vmi.create_mask %c32 : index -> !pto.vmi.mask<64xpred>
    %x = pto.vmi.load %src0[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16>
    %y = pto.vmi.load %src1[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16>
    %sum = pto.vmi.addf %x, %y
        : !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>
        -> !pto.vmi.vreg<64xf16>
    pto.vmi.masked_store %sum, %dst[%off], %mask
        : !pto.vmi.vreg<64xf16>, !pto.ptr<f16, ub>,
          !pto.vmi.mask<64xpred>
    return
  }

  func.func @f16_full_width_store_stays_contiguous(
      %src0: !pto.ptr<f16, ub>, %src1: !pto.ptr<f16, ub>,
      %dst: !pto.ptr<f16, ub>, %off: index) {
    %x = pto.vmi.load %src0[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16>
    %y = pto.vmi.load %src1[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16>
    %sum = pto.vmi.addf %x, %y
        : !pto.vmi.vreg<128xf16>, !pto.vmi.vreg<128xf16>
        -> !pto.vmi.vreg<128xf16>
    pto.vmi.store %sum, %dst[%off]
        : !pto.vmi.vreg<128xf16>, !pto.ptr<f16, ub>
    return
  }

  func.func @ui8_half_width_store_prefers_lane_stride2(
      %src0: !pto.ptr<ui8, ub>, %src1: !pto.ptr<ui8, ub>,
      %dst: !pto.ptr<ui8, ub>, %off: index) {
    %x = pto.vmi.load %src0[%off]
        : !pto.ptr<ui8, ub> -> !pto.vmi.vreg<128xui8>
    %y = pto.vmi.load %src1[%off]
        : !pto.ptr<ui8, ub> -> !pto.vmi.vreg<128xui8>
    %sum = pto.vmi.addi %x, %y
        : !pto.vmi.vreg<128xui8>, !pto.vmi.vreg<128xui8>
        -> !pto.vmi.vreg<128xui8>
    pto.vmi.store %sum, %dst[%off]
        : !pto.vmi.vreg<128xui8>, !pto.ptr<ui8, ub>
    return
  }

  func.func @ui8_quarter_width_store_prefers_lane_stride4(
      %src0: !pto.ptr<ui8, ub>, %src1: !pto.ptr<ui8, ub>,
      %dst: !pto.ptr<ui8, ub>, %off: index) {
    %x = pto.vmi.load %src0[%off]
        : !pto.ptr<ui8, ub> -> !pto.vmi.vreg<64xui8>
    %y = pto.vmi.load %src1[%off]
        : !pto.ptr<ui8, ub> -> !pto.vmi.vreg<64xui8>
    %sum = pto.vmi.addi %x, %y
        : !pto.vmi.vreg<64xui8>, !pto.vmi.vreg<64xui8>
        -> !pto.vmi.vreg<64xui8>
    pto.vmi.store %sum, %dst[%off]
        : !pto.vmi.vreg<64xui8>, !pto.ptr<ui8, ub>
    return
  }

  func.func @f16_store_does_not_override_channel_merge(
      %src: !pto.ptr<f16, ub>, %dst: !pto.ptr<f16, ub>, %off: index) {
    %c64 = arith.constant 64 : index
    %mask = pto.vmi.create_mask %c64 : index -> !pto.vmi.mask<128xpred>
    %x = pto.vmi.load %src[%off]
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16>
    %lo, %hi = "pto.vmi.channel_split"(%x)
        : (!pto.vmi.vreg<128xf16>)
        -> (!pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>)
    %merged = "pto.vmi.channel_merge"(%lo, %hi)
        : (!pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf16>)
        -> !pto.vmi.vreg<128xf16>
    pto.vmi.masked_store %merged, %dst[%off], %mask
        : !pto.vmi.vreg<128xf16>, !pto.ptr<f16, ub>,
          !pto.vmi.mask<128xpred>
    return
  }
}

// ASSIGN-LABEL: func.func @f16_store_prefers_lane_stride
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[Y:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.addf %[[X]], %[[Y]]
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: pto.vmi.store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>

// ASSIGN-LABEL: func.func @f16_masked_store_prefers_lane_stride
// ASSIGN: %[[MASK:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[Y:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.addf %[[X]], %[[Y]]
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[STORE_MASK:.*]] = pto.vmi.ensure_mask_granularity %[[MASK]]
// ASSIGN-SAME: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: pto.vmi.masked_store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN-SAME: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous, lane_stride = 2>>

// ASSIGN-LABEL: func.func @f16_full_width_store_stays_contiguous
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[Y:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.addf %[[X]], %[[Y]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
// ASSIGN: pto.vmi.store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>

// ASSIGN-LABEL: func.func @ui8_half_width_store_prefers_lane_stride2
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<128xui8, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[Y:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<128xui8, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.addi %[[X]], %[[Y]]
// ASSIGN-SAME: !pto.vmi.vreg<128xui8, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: pto.vmi.store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<128xui8, #pto.vmi.layout<contiguous, lane_stride = 2>>

// ASSIGN-LABEL: func.func @ui8_quarter_width_store_prefers_lane_stride4
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xui8, #pto.vmi.layout<contiguous, lane_stride = 4>>
// ASSIGN: %[[Y:.*]] = pto.vmi.load
// ASSIGN-SAME: !pto.vmi.vreg<64xui8, #pto.vmi.layout<contiguous, lane_stride = 4>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.addi %[[X]], %[[Y]]
// ASSIGN-SAME: !pto.vmi.vreg<64xui8, #pto.vmi.layout<contiguous, lane_stride = 4>>
// ASSIGN: pto.vmi.store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<64xui8, #pto.vmi.layout<contiguous, lane_stride = 4>>

// ASSIGN-LABEL: func.func @f16_store_does_not_override_channel_merge
// ASSIGN: "pto.vmi.channel_merge"
// ASSIGN-SAME: -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
// ASSIGN: pto.vmi.masked_store
// ASSIGN-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
// ASSIGN-SAME: !pto.vmi.mask<128xb16, #pto.vmi.layout<deinterleaved = 2>>

// LOWER-LABEL: func.func @f16_store_prefers_lane_stride
// LOWER: pto.vlds {{.*}} {dist = "UNPK_B16"} : !pto.ptr<f16, ub> -> !pto.vreg<128xf16>
// LOWER: pto.vsts {{.*}} {dist = "PK_B32"} : !pto.vreg<128xf16>, !pto.ptr<f16, ub>, !pto.mask<b32>

// LOWER-LABEL: func.func @f16_masked_store_prefers_lane_stride
// LOWER: pto.vlds {{.*}} {dist = "UNPK_B16"} : !pto.ptr<f16, ub> -> !pto.vreg<128xf16>
// LOWER: pto.vsts {{.*}} {dist = "PK_B32"} : !pto.vreg<128xf16>, !pto.ptr<f16, ub>, !pto.mask<b32>

// LOWER-LABEL: func.func @f16_full_width_store_stays_contiguous
// LOWER: pto.vsts {{.*}} : !pto.vreg<128xf16>, !pto.ptr<f16, ub>, !pto.mask<b16>

// LOWER-LABEL: func.func @ui8_half_width_store_prefers_lane_stride2
// LOWER: pto.vlds {{.*}} {dist = "UNPK_B8"}
// LOWER: pto.vsts {{.*}} {dist = "PK_B16"}

// LOWER-LABEL: func.func @ui8_quarter_width_store_prefers_lane_stride4
// LOWER: pto.vlds {{.*}} {dist = "UNPK4"} : !pto.ptr<ui8, ub> -> !pto.vreg<256xui8>
// LOWER: pto.vsts {{.*}} {dist = "PK4_B32"} : !pto.vreg<256xui8>, !pto.ptr<ui8, ub>, !pto.mask<b32>

// LOWER-LABEL: func.func @f16_store_does_not_override_channel_merge
// LOWER: pto.vldsx2 {{.*}}, "DINTLV_B16"
// LOWER: pto.vintlv
// LOWER: pto.vsts {{.*}} : !pto.vreg<128xf16>, !pto.ptr<f16, ub>, !pto.mask<b16>
