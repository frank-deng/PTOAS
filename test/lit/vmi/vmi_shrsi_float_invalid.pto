// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vmi_shrsi_float_invalid(
      %lhs: !pto.vmi.vreg<128xf16>,
      %rhs: !pto.vmi.vreg<128xf16>) {
    %shifted = pto.vmi.shrsi %lhs, %rhs
        : !pto.vmi.vreg<128xf16>, !pto.vmi.vreg<128xf16>
        -> !pto.vmi.vreg<128xf16>
    return
  }
}

// CHECK: 'pto.vmi.shrsi' op requires signless or signed i8, i16, or i32 VMI element type
