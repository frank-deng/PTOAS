// RUN: not pto-test-opt %s -split-input-file 2>&1 | FileCheck %s

module {
  func.func @vdhist_reject_si16_acc(
      %acc: !pto.vmi.vreg<256xsi16>,
      %source: !pto.vmi.vreg<256xui8>,
      %mask: !pto.vmi.mask<256xb8>) {
    %hist = pto.vmi.vdhist %acc, %source, %mask
        : !pto.vmi.vreg<256xsi16>, !pto.vmi.vreg<256xui8>, !pto.vmi.mask<256xb8>
        -> !pto.vmi.vreg<256xsi16>
    return
  }
}

// CHECK: 'pto.vmi.vdhist' op requires acc type to be !pto.vmi.vreg<128x{ui16|i16}> (Bin_N0-only) or !pto.vmi.vreg<256x{ui16|i16}>

// -----

module {
  func.func @vchist_reject_si8_source(
      %acc: !pto.vmi.vreg<256xui16>,
      %source: !pto.vmi.vreg<256xsi8>,
      %mask: !pto.vmi.mask<256xb8>) {
    %hist = pto.vmi.vchist %acc, %source, %mask
        : !pto.vmi.vreg<256xui16>, !pto.vmi.vreg<256xsi8>, !pto.vmi.mask<256xb8>
        -> !pto.vmi.vreg<256xui16>
    return
  }
}

// CHECK: 'pto.vmi.vchist' op requires source type to be !pto.vmi.vreg<Nx{ui8|i8}> (interpreted as unsigned)
