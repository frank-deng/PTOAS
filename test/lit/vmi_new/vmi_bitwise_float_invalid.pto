// RUN: not pto-test-opt %s -split-input-file 2>&1 | FileCheck %s

module {
  func.func @vmi_andi_float_invalid(
      %lhs: !pto.vmi.vreg<128xf32>,
      %rhs: !pto.vmi.vreg<128xf32>) {
    %out = pto.vmi.vand %lhs, %rhs
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>
        -> !pto.vmi.vreg<128xf32>
    return
  }
}

// CHECK: 'pto.vmi.vand' op requires integer-like VMI element type

// -----

module {
  func.func @vmi_ori_float_invalid(
      %lhs: !pto.vmi.vreg<128xf32>,
      %rhs: !pto.vmi.vreg<128xf32>) {
    %out = pto.vmi.vor %lhs, %rhs
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>
        -> !pto.vmi.vreg<128xf32>
    return
  }
}

// CHECK: 'pto.vmi.vor' op requires integer-like VMI element type

// -----

module {
  func.func @vmi_xori_float_invalid(
      %lhs: !pto.vmi.vreg<128xf32>,
      %rhs: !pto.vmi.vreg<128xf32>) {
    %out = pto.vmi.vxor %lhs, %rhs
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>
        -> !pto.vmi.vreg<128xf32>
    return
  }
}

// CHECK: 'pto.vmi.vxor' op requires integer-like VMI element type

// -----

module {
  func.func @vmi_not_float_invalid(%source: !pto.vmi.vreg<128xf32>) {
    %out = pto.vmi.vnot %source
        : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
    return
  }
}

// CHECK: 'pto.vmi.vnot' op requires integer-like VMI element type
