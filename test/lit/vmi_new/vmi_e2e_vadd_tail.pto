// RUN: ptoas --enable-vmi --pto-backend=vpto --pto-arch=a5 --vmi-two-stage-lowering --emit-vpto %s -o - 2>&1 | FileCheck %s

// E2E: vadd tail → two-stage lowering → VPTO.
// 100-lane f32 deinterleaved=2 vadd goes through unified→legacy→VPTO pipeline.

module {
  func.func @vadd_f32_e2e_tail(
      %a: !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %r = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vadd_f32_e2e_tail
// CHECK: pto.vadd
// CHECK-NOT: pto.vmi.
