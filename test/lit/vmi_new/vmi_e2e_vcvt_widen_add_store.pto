// RUN: ptoas --enable-vmi --pto-backend=vpto --pto-arch=a5 --vmi-two-stage-lowering --emit-vpto %s -o - 2>&1 | FileCheck %s

// E2E: vcvt fp widen + vadd + vstore chain → two-stage lowering → VPTO.

module {
  func.func @vcvt_widen_add_store_e2e(
      %src: !pto.ptr<f16, ub>, %dst: !pto.ptr<f32, ub>, %offset: index)
      -> !pto.ptr<f32, ub> {
    %v = pto.vmi.vload %src[%offset] {dist_mode = "continuous"}
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>
    %w = pto.vmi.vcvt %v
        : !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %cst = pto.vmi.vbrc 1.0 : f32 -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %a = pto.vmi.vadd %w, %cst
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %r = pto.vmi.vstore %a, %dst[%offset] {dist_mode = "continuous"}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>, !pto.ptr<f32, ub>
        -> !pto.ptr<f32, ub>
    return %r : !pto.ptr<f32, ub>
  }
}

// CHECK-LABEL: func.func @vcvt_widen_add_store_e2e
// CHECK: pto.vlds
// CHECK: pto.vcvt
// CHECK: pto.vadd
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
