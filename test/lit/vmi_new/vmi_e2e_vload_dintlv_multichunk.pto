// RUN: ptoas --enable-vmi --pto-backend=vpto --pto-arch=a5 --vmi-two-stage-lowering --emit-vpto %s -o - 2>&1 | FileCheck %s

// E2E: vload dintlv multichunk → two-stage lowering → VPTO.
// 256xf32 deinterleaved load produces 4 physical loads.

module {
  func.func @vload_dintlv_multichunk_e2e(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vload %src[%offset] {dist_mode = "dintlv"}
        : !pto.ptr<f32, ub>
        -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>,
           !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%lo)
        : (!pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    %p2, %p3 = "pto.vmi.unpack"(%hi)
        : (!pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_dintlv_multichunk_e2e
// CHECK-COUNT-4: pto.vlds
// CHECK-NOT: pto.vmi.
