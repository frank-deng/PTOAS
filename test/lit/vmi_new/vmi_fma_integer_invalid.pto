// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_fma_integer_invalid(
      %acc: !pto.vmi.vreg<64xi32>,
      %lhs: !pto.vmi.vreg<64xi32>,
      %rhs: !pto.vmi.vreg<64xi32>,
      %mask: !pto.vmi.mask<64xpred>) -> !pto.vmi.vreg<64xi32> {
    %out = pto.vmi.vmula %acc, %lhs, %rhs, %mask
        : !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>,
          !pto.vmi.vreg<64xi32>, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xi32>
    return %out : !pto.vmi.vreg<64xi32>
  }
}

// CHECK: failed to legalize operation 'pto.vmi.vmula' that was explicitly marked illegal
// CHECK: VMI-RESIDUAL-OP: failed to convert all VMI ops/types to VPTO
