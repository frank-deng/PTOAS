// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

module {
  func.func @group_reduce_addi_i16(
      %source: !pto.vmi.vreg<128xi16>,
      %mask: !pto.vmi.mask<128xpred>) {
    %sum = pto.vmi.vcadd %source, %mask {group = 8}
        : !pto.vmi.vreg<128xi16>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<8xi16>
    return
  }
}

// CHECK-LABEL: func.func @group_reduce_addi_i16(
// CHECK: pto.vcgadd {{.*}} : !pto.vreg<128xi16>, !pto.mask<b16> -> !pto.vreg<128xi16>
