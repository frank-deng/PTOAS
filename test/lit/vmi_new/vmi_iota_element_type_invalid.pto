// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vmi_iota_element_type_invalid(%base: i64) {
    %value = pto.vmi.vci %base
        : i64 -> !pto.vmi.vreg<64xi64>
    return
  }
}

// CHECK: 'pto.vmi.vci' op requires result element type to be integer 8/16/32 or f16/f32
