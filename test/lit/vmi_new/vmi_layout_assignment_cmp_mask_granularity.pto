// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN --implicit-check-not=pto.vmi.ensure_mask_layout
// RUN: pto-test-opt %s -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER --implicit-check-not=pto.vmi. --implicit-check-not='!pto.vmi.' --implicit-check-not=unrealized_conversion_cast

module {
  func.func @vmi_layout_assignment_cmp_mask_granularity(
      %lhs: !pto.vmi.vreg<64xf32>,
      %rhs: !pto.vmi.vreg<64xf32>,
      %dst: !pto.ptr<bf16, ub>,
      %offset: index) {
    %mask = pto.vmi.cmpf "olt", %lhs, %rhs
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32> -> !pto.vmi.mask<64xpred>
    %value = pto.vmi.truncf %lhs
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xbf16>
    pto.vmi.masked_store %value, %dst[%offset], %mask
        : !pto.vmi.vreg<64xbf16>, !pto.ptr<bf16, ub>, !pto.vmi.mask<64xpred>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_cmp_mask_granularity(
// ASSIGN: %[[MASK32:.*]] = pto.vmi.cmpf
// ASSIGN-SAME: -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[VALUE:.*]] = pto.vmi.truncf
// ASSIGN-SAME: -> !pto.vmi.vreg<64xbf16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: %[[MASK16:.*]] = pto.vmi.ensure_mask_granularity %[[MASK32]]
// ASSIGN-SAME: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>> -> !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous, lane_stride = 2>>
// ASSIGN: pto.vmi.masked_store %[[VALUE]]
// ASSIGN-SAME: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous, lane_stride = 2>>

// LOWER-LABEL: func.func @vmi_layout_assignment_cmp_mask_granularity(
// LOWER: %[[ALL:.*]] = pto.pset_b32 "PAT_ALL"
// LOWER: %[[MASK32:.*]] = pto.vcmp {{.*}}, {{.*}}, %[[ALL]], "lt"
// LOWER: pto.vsts {{.*}}, {{.*}}, %[[MASK32]] {dist = "PK_B32"}
