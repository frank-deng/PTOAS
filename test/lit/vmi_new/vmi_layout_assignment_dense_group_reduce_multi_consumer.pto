// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_dense_group_reduce_multi_consumer(
      %src: !pto.ptr<f32, ub>,
      %sum_out: !pto.ptr<f32, ub>,
      %copy_out: !pto.ptr<f32, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %c256 = arith.constant 256 : index
    %x = pto.vmi.vload %src[%off] : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
    %mask = pto.vmi.create_mask %c256 : index -> !pto.vmi.mask<256xpred>
    %sum = pto.vmi.vcadd %x, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.vstore %sum, %sum_out[%off], %c1 {group = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    pto.vmi.vstore %x, %copy_out[%off]
        : !pto.vmi.vreg<256xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_dense_group_reduce_multi_consumer(
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[MASK0:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: -> !pto.vmi.mask<256xb32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.group_reduce_addf %[[X]], %[[MASK0]]
// ASSIGN-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// ASSIGN: pto.vmi.group_store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>, !pto.ptr<f32, ub>
// ASSIGN-NOT: pto.vmi.ensure_layout %[[X]]
// ASSIGN: pto.vmi.store %[[X]]
// ASSIGN-SAME: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>, !pto.ptr<f32, ub>

// LOWER-LABEL: func.func @vmi_layout_assignment_dense_group_reduce_multi_consumer(
// LOWER-COUNT-2: pto.vldsx2
// LOWER-COUNT-2: pto.vdintlv
// LOWER-COUNT-3: pto.vadd
// LOWER: pto.vcgadd
// LOWER: pto.vsts
// LOWER-COUNT-4: pto.vsts
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
