// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_group_reduce_maxf_quant(
      %src: !pto.ptr<f32, ub>,
      %scale_out: !pto.ptr<f32, ub>,
      %out8: !pto.ptr<f8E4M3FN, ub>,
      %off: index) {
    %c8 = arith.constant 8 : index
    %c256 = arith.constant 256 : index
    %eps = arith.constant 1.000000e-04 : f32
    %fp8_max = arith.constant 4.480000e+02 : f32
    %mask = pto.vmi.create_mask %c256 : index -> !pto.vmi.mask<256xpred>
    %x = pto.vmi.vload %src[%off] : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
    %abs = pto.vmi.vabs %x : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf32>
    %amax_raw = pto.vmi.vcmax %abs, %mask {group = 2}
        : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<2xf32>
    %eps2 = pto.vmi.vbrc %eps : f32 -> !pto.vmi.vreg<2xf32>
    %amax = pto.vmi.vmax %amax_raw, %eps2
        : !pto.vmi.vreg<2xf32>, !pto.vmi.vreg<2xf32>
        -> !pto.vmi.vreg<2xf32>
    %fp8_max2 = pto.vmi.vbrc %fp8_max : f32 -> !pto.vmi.vreg<2xf32>
    %scale = pto.vmi.vdiv %amax, %fp8_max2
        : !pto.vmi.vreg<2xf32>, !pto.vmi.vreg<2xf32>
        -> !pto.vmi.vreg<2xf32>
    pto.vmi.vstore %scale, %scale_out[%off], %c8 {group = 2}
        : !pto.vmi.vreg<2xf32>, !pto.ptr<f32, ub>
    %scale_vec = pto.vmi.vbrc %scale {group = 2}
        : !pto.vmi.vreg<2xf32> -> !pto.vmi.vreg<256xf32>
    %q = pto.vmi.vdiv %x, %scale_vec
        : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
        -> !pto.vmi.vreg<256xf32>
    %q8 = pto.vmi.vcvt %q
        : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf8E4M3FN>
    pto.vmi.vstore %q8, %out8[%off]
        : !pto.vmi.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_group_reduce_maxf_quant(
// ASSIGN: %[[X:.*]] = pto.vmi.load
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[ABS:.*]] = pto.vmi.absf %[[X]]
// ASSIGN: %[[ABS_C:.*]] = pto.vmi.ensure_layout %[[ABS]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[AMAX_RAW:.*]] = pto.vmi.group_reduce_maxf %[[ABS_C]]
// ASSIGN-SAME: -> !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
// ASSIGN: %[[SCALE:.*]] = pto.vmi.divf
// ASSIGN-SAME: -> !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
// ASSIGN: pto.vmi.group_store %[[SCALE]]
// ASSIGN: %[[SCALE_VEC:.*]] = pto.vmi.group_broadcast %[[SCALE]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>
// ASSIGN: %[[SCALE_VEC_D:.*]] = pto.vmi.ensure_layout %[[SCALE_VEC]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[Q:.*]] = pto.vmi.divf %[[X]], %[[SCALE_VEC_D]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[Q8:.*]] = pto.vmi.truncf %[[Q]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>

// LOWER-LABEL: func.func @vmi_layout_assignment_group_reduce_maxf_quant(
// LOWER: %[[PAIR0:.*]] = pto.vmax
// LOWER: %[[RED0:.*]] = pto.vcmax %[[PAIR0]]
// LOWER: %[[PAIR1:.*]] = pto.vmax
// LOWER: %[[RED1:.*]] = pto.vcmax %[[PAIR1]]
// LOWER-NOT: pto.vcmax
// LOWER-NOT: pto.vsel
// LOWER: pto.vdiv
// LOWER: pto.vcvt {{.*}} {part = "P0", rnd = "R", sat = "SAT"}
// LOWER: pto.vor
// LOWER: pto.vsts
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
