// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_layout_assignment_non_load_s32_reduce(
      %base: !pto.ptr<f32, ub>,
      %bias: f32,
      %dst: !pto.ptr<f32, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %c256 = arith.constant 256 : index
    %mask = pto.vmi.create_mask %c256 : index -> !pto.vmi.mask<256xpred>
    %a = pto.vmi.vload %base[%off] : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
    %biasv = pto.vmi.vbrc %bias : f32 -> !pto.vmi.vreg<256xf32>
    %x = pto.vmi.vadd %a, %biasv
        : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
        -> !pto.vmi.vreg<256xf32>
    %sum = pto.vmi.vcadd %x, %mask
        {group = 8, reassoc}
        : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.vstore %sum, %dst[%off], %c1 {group = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_non_load_s32_reduce(
// ASSIGN-SAME: %[[BASE:arg[0-9]+]]: !pto.ptr<f32, ub>
// ASSIGN-SAME: %[[BIAS:arg[0-9]+]]: f32
// ASSIGN: %[[MASK:.*]] = pto.vmi.create_mask
// ASSIGN-SAME: -> !pto.vmi.mask<256xb32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[A:.*]] = pto.vmi.load %[[BASE]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[BIASV:.*]] = pto.vmi.broadcast %[[BIAS]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[X:.*]] = pto.vmi.addf %[[A]], %[[BIASV]]
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
// ASSIGN: %[[SUM:.*]] = pto.vmi.group_reduce_addf %[[X]], %[[MASK]]
// ASSIGN-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// ASSIGN: pto.vmi.group_store %[[SUM]]
// ASSIGN-SAME: !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>, !pto.ptr<f32, ub>

// LOWER-LABEL: func.func @vmi_layout_assignment_non_load_s32_reduce(
// LOWER-COUNT-4: pto.vdup %arg1
// LOWER-COUNT-7: pto.vadd {{.*}}, {{.*}}, {{.*}} : !pto.vreg<64xf32>
// LOWER: pto.vcgadd
// LOWER: %[[VL8:.*]] = pto.pge_b32 "PAT_VL8" : !pto.mask<b32>
// LOWER: pto.vsts {{.*}}, %arg2[%arg3], {{.*}} : !pto.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.mask<b32>
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
