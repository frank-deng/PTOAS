// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

// group_reduce_addf→vcadd.  group_store kept.
module {
  func.func @vmi_layout_assignment_vcadd_group16_s32_multitile_store(
      %source: !pto.vmi.vreg<512xf32>,
      %mask: !pto.vmi.mask<512xpred>,
      %dst: !pto.ptr<f32, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %sum = pto.vmi.vcadd %source, %mask {group = 16, reassoc}
        : !pto.vmi.vreg<512xf32>, !pto.vmi.mask<512xpred>
        -> !pto.vmi.vreg<16xf32>
    pto.vmi.group_store %sum, %dst[%off], %c1 {num_groups = 16}
        : !pto.vmi.vreg<16xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_vcadd_group16_s32_multitile_store(
// ASSIGN-SAME: %[[SOURCE:.*]]: !pto.vmi.vreg<512xf32, #pto.vmi.layout<contiguous>>
// ASSIGN-SAME: %[[MASK:.*]]: !pto.vmi.mask<512xb32, #pto.vmi.layout<contiguous>>
// ASSIGN: pto.vmi.ensure_layout %[[SOURCE]]
// ASSIGN-SAME: -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<deinterleaved = 4, block_elems = 8>>
// ASSIGN: pto.vmi.group_reduce_addf
// ASSIGN-SAME: -> !pto.vmi.vreg<16xf32, #pto.vmi.layout<num_groups = 16, slots = 8>>
// ASSIGN: pto.vmi.group_store

// LOWER-LABEL: func.func @vmi_layout_assignment_vcadd_group16_s32_multitile_store(
// LOWER: pto.vcgadd
// LOWER: pto.vsts
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
