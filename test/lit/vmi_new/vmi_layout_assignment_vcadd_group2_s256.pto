// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s

// V<512xf32> with group=2 → each group has 256 lanes (W=1024B = 32 BlockLanes).
// Layout assigns contiguous, result gets slots=1 (one scalar per group spread across 8 regs).
module {
  func.func @vmi_layout_assignment_vcadd_group2_s256(
      %source: !pto.vmi.vreg<512xf32>,
      %mask: !pto.vmi.mask<512xpred>) -> !pto.vmi.vreg<2xf32> {
    %out = pto.vmi.vcadd %source, %mask {group = 2, reassoc}
        : !pto.vmi.vreg<512xf32>, !pto.vmi.mask<512xpred>
        -> !pto.vmi.vreg<2xf32>
    return %out : !pto.vmi.vreg<2xf32>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vcadd_group2_s256(
// CHECK-SAME: %arg0: !pto.vmi.vreg<512xf32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %arg1: !pto.vmi.mask<512xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
// CHECK: pto.vmi.group_reduce_addf %arg0, %arg1
// CHECK-SAME: -> !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
// CHECK: return
