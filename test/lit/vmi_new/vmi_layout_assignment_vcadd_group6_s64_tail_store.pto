// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

// group_reduce_addf→vcadd, create_mask→pge, load→vload.  group_store kept.
module {
  func.func @vmi_layout_assignment_vcadd_group6_s64_tail_store(
      %src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>, %off: index) {
    %c8 = arith.constant 8 : index
    %c384 = arith.constant 384 : index
    %mask = pto.vmi.pge "PAT_VL384" : !pto.vmi.mask<384xpred>
    %x = pto.vmi.vload %src[%off] : !pto.ptr<f32, ub> -> !pto.vmi.vreg<384xf32>
    %sum = pto.vmi.vcadd %x, %mask {group = 6, reassoc}
        : !pto.vmi.vreg<384xf32>, !pto.vmi.mask<384xpred>
        -> !pto.vmi.vreg<6xf32>
    pto.vmi.group_store %sum, %dst[%off], %c8 {num_groups = 6}
        : !pto.vmi.vreg<6xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_vcadd_group6_s64_tail_store(
// ASSIGN: pto.vmi.load
// ASSIGN-SAME: -> !pto.vmi.vreg<384xf32, #pto.vmi.layout<contiguous>>
// ASSIGN: pto.vmi.group_reduce_addf
// ASSIGN-SAME: -> !pto.vmi.vreg<6xf32, #pto.vmi.layout<num_groups = 6, slots = 1>>
// ASSIGN: pto.vmi.group_store

// LOWER-LABEL: func.func @vmi_layout_assignment_vcadd_group6_s64_tail_store(
// LOWER: pto.vlds
// LOWER: pto.vcgadd
// LOWER: pto.vsts
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
