// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

// group_reduce_addf→vcadd, group_broadcast→vbrc, mulf→vmul.  group_store kept.
module {
  func.func @vmi_layout_assignment_vcadd_group8_broadcast_reduce(
      %source: !pto.vmi.vreg<256xf32>,
      %mask: !pto.vmi.mask<256xpred>,
      %dst: !pto.ptr<f32, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %sum = pto.vmi.vcadd %source, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xf32>
    %broadcast = pto.vmi.group_broadcast %sum {num_groups = 8}
        : !pto.vmi.vreg<8xf32> -> !pto.vmi.vreg<256xf32>
    %scaled = pto.vmi.vmul %source, %broadcast
        : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
        -> !pto.vmi.vreg<256xf32>
    %scaled_sum = pto.vmi.vcadd %scaled, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xf32>
    pto.vmi.group_store %scaled_sum, %dst[%off], %c1 {num_groups = 8}
        : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_layout_assignment_vcadd_group8_broadcast_reduce(
// ASSIGN: pto.vmi.group_reduce_addf
// ASSIGN-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// ASSIGN: pto.vmi.group_broadcast
// ASSIGN: pto.vmi.mulf
// ASSIGN: pto.vmi.group_reduce_addf

// LOWER: pto.vsts
// LOWER-NOT: pto.vmi.
// LOWER-NOT: !pto.vmi.
// LOWER-NOT: unrealized_conversion_cast
