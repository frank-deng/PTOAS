// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s

module {
  func.func @vmi_layout_assignment_vcadd_group8_slots8(
      %source: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>) -> !pto.vmi.vreg<8xf32> {
    %out = pto.vmi.vcadd %source, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<8xf32>
    return %out : !pto.vmi.vreg<8xf32>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vcadd_group8_slots8(
// CHECK-SAME: %arg0: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %arg1: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// CHECK: pto.vmi.group_reduce_addf %arg0, %arg1
// CHECK-SAME: -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
// CHECK: return
