// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s

// Partial slots8: f16 with group=4 and group=12.  Layout assigns deinterleaved=4.
module {
  func.func @vmi_layout_assignment_vcadd_f16_s64_g4(
      %source: !pto.vmi.vreg<256xf16>,
      %mask: !pto.vmi.mask<256xpred>)
      -> !pto.vmi.vreg<4xf16> {
    %out = pto.vmi.vcadd %source, %mask
        {group = 4, reassoc}
        : !pto.vmi.vreg<256xf16>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<4xf16>
    return %out : !pto.vmi.vreg<4xf16>
  }

  func.func @vmi_layout_assignment_vcadd_f16_s64_g12(
      %source: !pto.vmi.vreg<768xf16>,
      %mask: !pto.vmi.mask<768xpred>)
      -> !pto.vmi.vreg<12xf16> {
    %out = pto.vmi.vcadd %source, %mask
        {group = 12, reassoc}
        : !pto.vmi.vreg<768xf16>, !pto.vmi.mask<768xpred>
        -> !pto.vmi.vreg<12xf16>
    return %out : !pto.vmi.vreg<12xf16>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vcadd_f16_s64_g4(
// CHECK-SAME: %arg0: !pto.vmi.vreg<256xf16, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %arg1: !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<4xf16, #pto.vmi.layout<num_groups = 4, slots = 8>>
// CHECK: pto.vmi.ensure_layout %arg0
// CHECK-SAME: -> !pto.vmi.vreg<256xf16, #pto.vmi.layout<deinterleaved = 4, block_elems = 8>>
// CHECK: pto.vmi.group_reduce_addf
// CHECK-SAME: -> !pto.vmi.vreg<4xf16, #pto.vmi.layout<num_groups = 4, slots = 8>>
// CHECK: return

// CHECK-LABEL: func.func @vmi_layout_assignment_vcadd_f16_s64_g12(
// CHECK-SAME: %arg0: !pto.vmi.vreg<768xf16, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %arg1: !pto.vmi.mask<768xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<12xf16, #pto.vmi.layout<num_groups = 12, slots = 8>>
// CHECK: pto.vmi.group_reduce_addf
// CHECK-SAME: -> !pto.vmi.vreg<12xf16, #pto.vmi.layout<num_groups = 12, slots = 8>>
// CHECK: return
