// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s

module {
  func.func @vmi_layout_assignment_vcadd_i32(
      %source: !pto.vmi.vreg<64xi32>,
      %mask: !pto.vmi.mask<64xpred>) -> !pto.vmi.vreg<1xi32> {
    %out = pto.vmi.vcadd %source, %mask
        : !pto.vmi.vreg<64xi32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<1xi32>
    return %out : !pto.vmi.vreg<1xi32>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vcadd_i32(
// CHECK-SAME: %[[SRC:.*]]: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %[[MASK:.*]]: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<1xi32, #pto.vmi.layout<contiguous>>
// CHECK: "pto.vmi.constant"() <{value = dense<0> : tensor<1xi32>}> : () -> !pto.vmi.vreg<1xi32, #pto.vmi.layout<contiguous>>
// CHECK: pto.vmi.reduce_addi %[[SRC]], %{{.*}}, %[[MASK]]
// CHECK-SAME: !pto.vmi.vreg<1xi32, #pto.vmi.layout<contiguous>>
// CHECK: return
