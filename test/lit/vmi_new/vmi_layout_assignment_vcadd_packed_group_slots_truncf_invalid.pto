// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

// group_reduce_addf→vcadd, truncf→vcvt.  group_store kept.
module {
  func.func @vmi_layout_assignment_vcadd_packed_group_slots_truncf_invalid(
      %source: !pto.vmi.vreg<128xf32>,
      %mask: !pto.vmi.mask<128xpred>,
      %dst: !pto.ptr<f16, ub>,
      %off: index) {
    %c1 = arith.constant 1 : index
    %sum = pto.vmi.vcadd %source, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<128xf32>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<8xf32>
    %h = pto.vmi.vcvt %sum
        : !pto.vmi.vreg<8xf32> -> !pto.vmi.vreg<8xf16>
    pto.vmi.group_store %h, %dst[%off], %c1 {num_groups = 8}
        : !pto.vmi.vreg<8xf16>, !pto.ptr<f16, ub>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.truncf operand #0 has type
// CHECK-SAME: #pto.vmi.layout<num_groups = 8, slots = 8>
// CHECK-SAME: requires
// CHECK-SAME: #pto.vmi.layout<deinterleaved = 2>
