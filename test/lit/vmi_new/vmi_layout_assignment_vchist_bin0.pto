// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s

module {
  func.func @vmi_layout_assignment_vchist_bin0(
      %acc: !pto.vmi.vreg<128xui16>,
      %source: !pto.vmi.vreg<300xui8>,
      %mask: !pto.vmi.mask<300xpred>)
      -> !pto.vmi.vreg<128xui16> {
    %hist = pto.vmi.vchist %acc, %source, %mask
        : !pto.vmi.vreg<128xui16>, !pto.vmi.vreg<300xui8>,
          !pto.vmi.mask<300xpred> -> !pto.vmi.vreg<128xui16>
    return %hist : !pto.vmi.vreg<128xui16>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vchist_bin0(
// CHECK-SAME: %[[ACC:.*]]: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %[[SRC:.*]]: !pto.vmi.vreg<300xui8, #pto.vmi.layout<contiguous>>
// CHECK-SAME: %[[MASK:.*]]: !pto.vmi.mask<300xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
// CHECK: %[[MASK_D4:.*]] = pto.vmi.ensure_mask_layout %[[MASK]]
// CHECK-SAME: !pto.vmi.mask<300xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.mask<300xb32, #pto.vmi.layout<deinterleaved = 4>>
// CHECK: %[[MASK_B8:.*]] = pto.vmi.ensure_mask_granularity %[[MASK_D4]]
// CHECK-SAME: !pto.vmi.mask<300xb32, #pto.vmi.layout<deinterleaved = 4>>
// CHECK-SAME: !pto.vmi.mask<300xb8, #pto.vmi.layout<contiguous>>
// CHECK: %[[HIST:.*]] = pto.vmi.vchist %[[ACC]], %[[SRC]], %[[MASK_B8]]
// CHECK-SAME: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.vreg<300xui8, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.mask<300xb8, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
// CHECK: return %[[HIST]]
