// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment | FileCheck %s

module {
  func.func @vmi_layout_assignment_vcmax(
      %source: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>) -> !pto.vmi.vreg<1xf32> {
    %out = pto.vmi.vcmax %source, %mask
        : !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<1xf32>
    return %out : !pto.vmi.vreg<1xf32>
  }

  func.func @vmi_layout_assignment_vcmin(
      %source: !pto.vmi.vreg<128xf16>,
      %mask: !pto.vmi.mask<128xpred>) -> !pto.vmi.vreg<1xf16> {
    %out = pto.vmi.vcmin %source, %mask
        : !pto.vmi.vreg<128xf16>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<1xf16>
    return %out : !pto.vmi.vreg<1xf16>
  }
}

// CHECK-LABEL: func.func @vmi_layout_assignment_vcmax(
// CHECK-SAME: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>
// CHECK: "pto.vmi.constant"() <{value = dense<0xFF800000> : tensor<1xf32>}>
// CHECK: pto.vmi.reduce_maxf
// CHECK-SAME: !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>
// CHECK: return

// CHECK-LABEL: func.func @vmi_layout_assignment_vcmin(
// CHECK-SAME: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
// CHECK-SAME: !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>
// CHECK-SAME: -> !pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>
// CHECK: "pto.vmi.constant"() <{value = dense<0x7C00> : tensor<1xf16>}>
// CHECK: pto.vmi.ensure_mask_granularity
// CHECK-SAME: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
// CHECK: pto.vmi.reduce_minf
// CHECK-SAME: !pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>
// CHECK: return
