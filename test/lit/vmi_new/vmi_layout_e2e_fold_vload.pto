// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-fold 2>&1 | FileCheck %s

// E2E fold: vload layout fold optimization.

module {
  func.func @fold_vload_e2e(%src: !pto.ptr<f32, ub>, %off: index)
      -> !pto.vmi.vreg<128xf32> {
    %x = pto.vmi.vload %src[%off] {dist_mode = "continuous"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<128xf32>
    return %x : !pto.vmi.vreg<128xf32>
  }
}

// CHECK: pto.vmi.load
// CHECK-NOT: error:
