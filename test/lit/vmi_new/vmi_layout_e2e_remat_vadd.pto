// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-rematerialize 2>&1 | FileCheck %s

// E2E remat: data rematerialization for vadd.

module {
  func.func @remat_vadd_e2e(%a: !pto.vmi.vreg<128xf32>, %b: !pto.vmi.vreg<128xf32>)
      -> (!pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>) {
    %r1 = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
    %r2 = pto.vmi.vadd %r1, %b
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
    return %r1, %r2 : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32>
  }
}

// CHECK: pto.vmi.addf
// CHECK-NOT: error:
