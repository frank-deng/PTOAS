// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// E2E layout: scf.for loop with vadd, vcvt widen + narrow.

module {
  func.func @scf_for_vadd_e2e(%a: !pto.vmi.vreg<128xf16>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %init = pto.vmi.vcvt %a : !pto.vmi.vreg<128xf16> -> !pto.vmi.vreg<128xf32>
    %result = scf.for %i = %c0 to %c2 step %c1
        iter_args(%acc = %init) -> (!pto.vmi.vreg<128xf32>) {
      %next = pto.vmi.vadd %acc, %acc
          : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
      scf.yield %next : !pto.vmi.vreg<128xf32>
    }
    return
  }
}

// CHECK-LABEL: func.func @scf_for_vadd_e2e
// CHECK: scf.for
// CHECK: pto.vadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
