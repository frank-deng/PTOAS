// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

// E2E layout: vadd + vmul full pipeline. Just verify no residual VMI ops.

module {
  func.func @vadd_vmul_e2e(
      %a: !pto.vmi.vreg<128xf32>, %b: !pto.vmi.vreg<128xf32>)
      -> !pto.vmi.vreg<128xf32> {
    %add = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
    %mul = pto.vmi.vmul %add, %b
        : !pto.vmi.vreg<128xf32>, !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
    return %mul : !pto.vmi.vreg<128xf32>
  }
}

// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: error:
