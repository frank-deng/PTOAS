// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy 2>&1 | FileCheck %s

// E2E: vbrc with num_groups → skipped by two-stage lowering (Category D path).

module {
  func.func @vbrc_group_skip(%s: !pto.vmi.vreg<8xf32,
      #pto.vmi.layout<num_groups = 8, slots = 1>>) -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vbrc %s {num_groups = 8}
        : !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 1>>
        -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}

// vbrc with num_groups is preserved (skipped) in two-stage lowering
// CHECK: pto.vmi.vbrc
// CHECK-NOT: error:
