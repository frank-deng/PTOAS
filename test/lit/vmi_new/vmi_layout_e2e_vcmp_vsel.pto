// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

// E2E layout: vcmp + vsel full pipeline.

module {
  func.func @vcmp_vsel_e2e(
      %a: !pto.vmi.vreg<64xf32>, %b: !pto.vmi.vreg<64xf32>,
      %t: !pto.vmi.vreg<64xf32>, %f: !pto.vmi.vreg<64xf32>,
      %seed: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    %m = pto.vmi.vcmp %a, %b, %seed {cmp = "lt"}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.mask<64xpred>
    %r = pto.vmi.vsel %m, %t, %f
        : !pto.vmi.mask<64xpred>, !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
        -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}

// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: error:
