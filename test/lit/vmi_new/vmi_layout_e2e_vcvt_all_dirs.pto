// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

// E2E layout: vcvt fp widen + narrow + fptosi full pipeline.

module {
  func.func @vcvt_fp_widen_e2e(%a: !pto.vmi.vreg<128xf16>) -> !pto.vmi.vreg<128xf32> {
    %r = pto.vmi.vcvt %a : !pto.vmi.vreg<128xf16> -> !pto.vmi.vreg<128xf32>
    return %r : !pto.vmi.vreg<128xf32>
  }
  func.func @vcvt_fp_narrow_e2e(%a: !pto.vmi.vreg<128xf32>) -> !pto.vmi.vreg<128xf16> {
    %r = pto.vmi.vcvt %a : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf16>
    return %r : !pto.vmi.vreg<128xf16>
  }
  func.func @vcvt_fptosi_e2e(%a: !pto.vmi.vreg<64xf32>) -> !pto.vmi.vreg<64xi32> {
    %r = pto.vmi.vcvt %a : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xi32>
    return %r : !pto.vmi.vreg<64xi32>
  }
}

// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: error:
