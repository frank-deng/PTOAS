// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto 2>&1 | FileCheck %s

// E2E layout: vload → vadd → vstore masked continuous.

module {
  func.func @vload_add_vstore_e2e(
      %src: !pto.ptr<f32, ub>, %dst: !pto.ptr<f32, ub>, %off: index) {
    %x = pto.vmi.vload %src[%off] {dist_mode = "continuous"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    %x2 = pto.vmi.vadd %x, %x
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %x2, %dst[%off] {dist_mode = "continuous"}
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: error:
