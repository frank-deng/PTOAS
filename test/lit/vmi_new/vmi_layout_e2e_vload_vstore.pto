// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// E2E layout: vload + vstore continuous f16→f32 via vcvt.

module {
  func.func @vload_vcvt_vstore_e2e(
      %src: !pto.ptr<f16, ub>, %dst: !pto.ptr<f32, ub>, %off: index) {
    %x16 = pto.vmi.vload %src[%off] {dist_mode = "continuous"}
        : !pto.ptr<f16, ub> -> !pto.vmi.vreg<128xf16>
    %x32 = pto.vmi.vcvt %x16
        : !pto.vmi.vreg<128xf16> -> !pto.vmi.vreg<128xf32>
    pto.vmi.vstore %x32, %dst[%off] {dist_mode = "continuous"}
        : !pto.vmi.vreg<128xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vload_vcvt_vstore_e2e
// CHECK: pto.vlds
// CHECK: pto.vcvt
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
