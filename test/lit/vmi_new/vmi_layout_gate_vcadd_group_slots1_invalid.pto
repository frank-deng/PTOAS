// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -pto-validate-vmi-layout-ir 2>&1 | FileCheck %s

// 256xf32 with group=8 and slots=1 → 32 lanes per group (4 BlockLanes).  slots=1 not valid here.
module {
  func.func @vmi_layout_gate_vcadd_group_slots1_invalid(
      %source: !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.vcadd %source, %mask
        {group = 8, reassoc}
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 1>>
    return
  }
}

// CHECK: VMI-LAYOUT-CONTRACT: pto.vmi.group_reduce_addf has no registered group_slots layout support
// CHECK-SAME: stable group_reduce_add slots=1 support group sizes that are multiples of one physical chunk
