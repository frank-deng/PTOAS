// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -pto-validate-vmi-layout-ir 2>&1 | FileCheck %s

// 96-lane source with group=8 → 12 lanes per group, not a supported block size.
module {
  func.func @vmi_layout_gate_vcadd_group_support_invalid(
      %source: !pto.vmi.vreg<96xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<96xb32, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.vcadd %source, %mask
        {group = 8, reassoc}
        : !pto.vmi.vreg<96xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<96xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
    return
  }
}

// CHECK: VMI-LAYOUT-CONTRACT: pto.vmi.group_reduce_addf has no registered group_slots layout support
// CHECK-SAME: stable group_reduce_add slots=8 support group sizes VLaneElems, 2*VLaneElems, or 4*VLaneElems
