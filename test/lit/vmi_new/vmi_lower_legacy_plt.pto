// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Two-stage lowering: vmi.plt → vmi.create_mask (dynamic) with remainder chain.

module {
  // CHECK-LABEL: func.func @plt_dynamic
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.plt
  func.func @plt_dynamic(
      %n: i32)
      -> (!pto.vmi.mask<128xpred>, i32) {
    %m, %r = pto.vmi.plt %n : i32 -> !pto.vmi.mask<128xpred>, i32
    return %m, %r : !pto.vmi.mask<128xpred>, i32
  }
}
