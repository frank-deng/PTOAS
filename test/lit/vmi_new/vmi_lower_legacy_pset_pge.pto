// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Two-stage lowering: vmi.pset → vmi.create_mask (all lanes)
//                     vmi.pge  → vmi.create_mask (N lanes)

module {
  // CHECK-LABEL: func.func @pset_all_active
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.pset
  func.func @pset_all_active()
      -> !pto.vmi.mask<128xpred> {
    %m = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<128xpred>
    return %m : !pto.vmi.mask<128xpred>
  }

  // CHECK-LABEL: func.func @pge_vl64
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.pge
  func.func @pge_vl64()
      -> !pto.vmi.mask<128xpred> {
    %m = pto.vmi.pge "PAT_VL64" : !pto.vmi.mask<128xpred>
    return %m : !pto.vmi.mask<128xpred>
  }

  // CHECK-LABEL: func.func @pge_vl96
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.pge
  func.func @pge_vl96()
      -> !pto.vmi.mask<128xpred> {
    %m = pto.vmi.pge "PAT_VL96" : !pto.vmi.mask<128xpred>
    return %m : !pto.vmi.mask<128xpred>
  }

  // CHECK-LABEL: func.func @pset_pred_granularity
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.pset
  func.func @pset_pred_granularity()
      -> !pto.vmi.mask<256xpred> {
    %m = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
    return %m : !pto.vmi.mask<256xpred>
  }

  // CHECK-LABEL: func.func @pge_pred_granularity
  // CHECK: pto.vmi.create_mask
  // CHECK-NOT: pto.vmi.pge
  func.func @pge_pred_granularity()
      -> !pto.vmi.mask<512xpred> {
    %m = pto.vmi.pge "PAT_VL256" : !pto.vmi.mask<512xpred>
    return %m : !pto.vmi.mask<512xpred>
  }
}
