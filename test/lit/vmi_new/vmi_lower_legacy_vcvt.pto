// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Two-stage lowering: vmi.vcvt → type-dispatched legacy cast ops.

module {
  // CHECK-LABEL: func.func @vcvt_fp_widen
  // CHECK: pto.vmi.extf
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_fp_widen(
      %a: !pto.vmi.vreg<64xf16>)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xf16> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }

  // CHECK-LABEL: func.func @vcvt_fp_narrow
  // CHECK: pto.vmi.truncf
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_fp_narrow(
      %a: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xf16> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf16>
    return %r : !pto.vmi.vreg<64xf16>
  }

  // CHECK-LABEL: func.func @vcvt_fptosi
  // CHECK: pto.vmi.fptosi
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_fptosi(
      %a: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xi32> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xi32>
    return %r : !pto.vmi.vreg<64xi32>
  }

  // CHECK-LABEL: func.func @vcvt_sitofp
  // CHECK: pto.vmi.sitofp
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_sitofp(
      %a: !pto.vmi.vreg<64xi32>)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xi32> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }

  // CHECK-LABEL: func.func @vcvt_int_widen_signed
  // CHECK: pto.vmi.extsi
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_int_widen_signed(
      %a: !pto.vmi.vreg<64xi16>)
      -> !pto.vmi.vreg<64xi32> {
    %r = pto.vmi.vcvt %a {sign = "S"}
        : !pto.vmi.vreg<64xi16> -> !pto.vmi.vreg<64xi32>
    return %r : !pto.vmi.vreg<64xi32>
  }

  // CHECK-LABEL: func.func @vcvt_int_widen_unsigned
  // CHECK: pto.vmi.extui
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_int_widen_unsigned(
      %a: !pto.vmi.vreg<64xui16>)
      -> !pto.vmi.vreg<64xui32> {
    %r = pto.vmi.vcvt %a {sign = "U"}
        : !pto.vmi.vreg<64xui16> -> !pto.vmi.vreg<64xui32>
    return %r : !pto.vmi.vreg<64xui32>
  }

  // CHECK-LABEL: func.func @vcvt_int_narrow
  // CHECK: pto.vmi.trunci
  // CHECK-NOT: pto.vmi.vcvt
  func.func @vcvt_int_narrow(
      %a: !pto.vmi.vreg<64xi32>)
      -> !pto.vmi.vreg<64xi16> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xi32> -> !pto.vmi.vreg<64xi16>
    return %r : !pto.vmi.vreg<64xi16>
  }
}
