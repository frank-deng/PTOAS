// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Two-stage lowering: vmi.vload → vmi.load / vmi.deinterleave_load (by dist_mode).

module {
  // CHECK-LABEL: func.func @vload_continuous
  // CHECK: pto.vmi.load
  // CHECK-NOT: pto.vmi.vload
  func.func @vload_continuous(
      %src: !pto.ptr<f32, ub>,
      %offset: index)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vload %src[%offset] {dist_mode = "continuous"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }

  // CHECK-LABEL: func.func @vload_dintlv
  // CHECK: pto.vmi.deinterleave_load
  // CHECK-NOT: pto.vmi.vload
  func.func @vload_dintlv(
      %src: !pto.ptr<f32, ub>,
      %offset: index)
      -> (!pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vload %src[%offset] {dist_mode = "dintlv"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
    return %lo, %hi : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
  }

  // CHECK-LABEL: func.func @vload_skip_unpack
  // CHECK-NOT: pto.vmi.load
  // CHECK: pto.vmi.vload {dist_mode = "unpack"}
  func.func @vload_skip_unpack(
      %src: !pto.ptr<f32, ub>,
      %offset: index)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vload %src[%offset] {dist_mode = "unpack"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
