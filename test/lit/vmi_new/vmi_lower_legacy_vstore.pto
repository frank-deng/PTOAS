// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Two-stage lowering: vmi.vstore → vmi.store / vmi.masked_store / vmi.interleave_store.

module {
  // CHECK-LABEL: func.func @vstore_continuous_no_mask
  // CHECK: pto.vmi.store
  // CHECK-NOT: pto.vmi.vstore
  func.func @vstore_continuous_no_mask(
      %val: !pto.vmi.vreg<64xf32>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index) {
    pto.vmi.vstore %val, %dst[%offset] {dist_mode = "continuous"}
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }

  // CHECK-LABEL: func.func @vstore_continuous_masked
  // CHECK: pto.vmi.masked_store
  // CHECK-NOT: pto.vmi.vstore
  func.func @vstore_continuous_masked(
      %val: !pto.vmi.vreg<64xf32>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index,
      %mask: !pto.vmi.mask<64xpred>) {
    pto.vmi.vstore %val, %dst[%offset], %mask {dist_mode = "continuous"}
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.vmi.mask<64xpred>
    return
  }

  // CHECK-LABEL: func.func @vstore_dintlv
  // CHECK: pto.vmi.interleave_store
  // CHECK-NOT: pto.vmi.vstore
  func.func @vstore_dintlv(
      %lo: !pto.vmi.vreg<64xf32>,
      %hi: !pto.vmi.vreg<64xf32>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index) {
    pto.vmi.vstore %lo, %hi, %dst[%offset] {dist_mode = "dintlv"}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }
}
