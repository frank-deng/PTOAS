// RUN: not pto-test-opt %s 2>&1 | FileCheck %s

module {
  // plt with non-i32 scalar input: ODS operand constraint rejects i64
  func.func @vmi_plt_non_i32_scalar_invalid(%rem: i64) {
    %mask, %next = pto.vmi.plt %rem
        : i64 -> !pto.vmi.mask<128 x pred>, i64
    return
  }
}

// CHECK: must be 32-bit signless integer
