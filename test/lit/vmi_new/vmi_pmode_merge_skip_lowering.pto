// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// Cross-feature: pmode="merge" ops must be SKIPPED by two-stage lowering.
// They stay as unified ops and go directly to VPTO lowering.

module {
  // CHECK-LABEL: func.func @vadd_merge_stays_unified
  // CHECK: pto.vmi.vadd
  // CHECK-SAME: pmode = "merge"
  func.func @vadd_merge_stays_unified(
      %a: !pto.vmi.vreg<64xf32>,
      %b: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vadd %a, %b, %mask {pmode = "merge"}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
