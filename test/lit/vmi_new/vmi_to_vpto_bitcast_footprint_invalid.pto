// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_bitcast_footprint_invalid(
      %source: !pto.vmi.vreg<65xf32, #pto.vmi.layout<deinterleaved = 2>>) {
    %out = pto.vmi.vinterpret_cast %source
        : !pto.vmi.vreg<65xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<130xi16, #pto.vmi.layout<deinterleaved = 2>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vinterpret_cast requires matching source/result layouts
// CHECK-SAME: identical physical arity and matching per-chunk logical bit footprints
// CHECK-SAME: requires matching logical bit footprint in every physical chunk
