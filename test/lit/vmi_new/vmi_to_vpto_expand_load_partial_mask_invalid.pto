// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_expand_load_partial_mask_invalid(
      %src: !pto.ptr<f32, ub>,
      %offset: index,
      %passthru: !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %active = arith.constant 4 : index
    %mask = pto.vmi.create_mask %active
        : index -> !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>
    %out = pto.vmi.vexpand_load %src[%offset], %mask, %passthru
        : !pto.ptr<f32, ub>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>
    %part0, %part1 = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<128xf32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %part0, %part1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vexpand_load direct lowering is currently supported
// CHECK-SAME: one physical chunk
