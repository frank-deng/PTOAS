// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

// f32 -> i32 (FpToSi) contract has requiresSat=true; a user-driven NOSAT must
// be caught by the physical pto.vcvt verifier.

module {
  func.func @vmi_to_vpto_fptosi_f32_to_i32_nosat_invalid(
      %input: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>)
      -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>,
          !pto.vreg<64xi32>, !pto.vreg<64xi32>) {
    %wide = pto.vmi.vcvt %input {saturate = "NOSAT"}
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xi32, #pto.vmi.layout<deinterleaved = 4>>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%wide)
        : (!pto.vmi.vreg<256xi32, #pto.vmi.layout<deinterleaved = 4>>)
        -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>,
            !pto.vreg<64xi32>, !pto.vreg<64xi32>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<64xi32>, !pto.vreg<64xi32>,
          !pto.vreg<64xi32>, !pto.vreg<64xi32>
  }
}

// CHECK: 'pto.vcvt' op requires sat attr for this vcvt type pair