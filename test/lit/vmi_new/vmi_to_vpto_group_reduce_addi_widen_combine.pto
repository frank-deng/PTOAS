// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_group_reduce_addi_widen_combine(
      %source: !pto.vmi.vreg<256xi16, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xi16> {
    %mask = "pto.vmi.constant_mask"() {
      value = dense<true> : tensor<256xi1>
    } : () -> !pto.vmi.mask<256xb16, #pto.vmi.layout<contiguous>>
    %out = pto.vmi.vcadd %source, %mask {group = 1}
        : !pto.vmi.vreg<256xi16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<1xi16, #pto.vmi.layout<num_groups = 1, slots = 1>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xi16, #pto.vmi.layout<num_groups = 1, slots = 1>>)
        -> !pto.vreg<128xi16>
    return %part : !pto.vreg<128xi16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_group_reduce_addi_widen_combine(
// CHECK: %[[MASK0:.*]] = pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
// CHECK: pto.pset_b16 "PAT_ALL" : !pto.mask<b16>
// CHECK: %[[MERGED:.*]] = pto.vadd %arg0, %arg1, %[[MASK0]] : !pto.vreg<128xi16>, !pto.vreg<128xi16>, !pto.mask<b16> -> !pto.vreg<128xi16>
// CHECK: %[[REDUCED:.*]] = pto.vcadd %[[MERGED]], %[[MASK0]] : !pto.vreg<128xi16>, !pto.mask<b16> -> !pto.vreg<64xi32>
// CHECK: %[[RESULT:.*]] = pto.vbitcast %[[REDUCED]] : !pto.vreg<64xi32> -> !pto.vreg<128xi16>
// CHECK: return %[[RESULT]]
// CHECK-NOT: pto.vcadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
