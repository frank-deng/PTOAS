// RUN: not pto-test-opt %s -split-input-file -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_addf_f8_invalid(
      %lhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.addf %lhs, %rhs
        : !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.addf direct lowering requires f16/bf16/f32 element type
// CHECK-SAME: requires f16/bf16/f32 element type for direct VPTO lowering

// -----

module {
  func.func @vmi_to_vpto_divf_bf16_invalid(
      %lhs: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
      %rhs: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.vdiv %lhs, %rhs
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vdiv direct lowering requires f16/f32 element type
// CHECK-SAME: requires f16/f32 element type for direct VPTO lowering

// -----

module {
  func.func @vmi_to_vpto_sqrt_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %out = pto.vmi.vsqrt %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vsqrt direct lowering requires f16/f32 element type
// CHECK-SAME: requires f16/f32 element type for direct VPTO lowering

// -----

module {
