// RUN: ptoas --enable-vmi --pto-backend=vpto --pto-arch=a5 --emit-vpto -o - %s 2>&1 | FileCheck %s

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_to_vpto_plt_integration(%rem: i32) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    pto.vecscope {
      %mask, %next = pto.vmi.plt %rem : i32 -> !pto.vmi.mask<128 x pred>, i32
    }
    return
  }
}

// CHECK: module attributes {pto.backend = "vpto", pto.target_arch = "a5"}
// CHECK: func.func @vmi_to_vpto_plt_integration
// CHECK-NOT: pto.vmi.
