// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment | FileCheck %s --check-prefix=ASSIGN
// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-mask-granularity-assignment -vmi-layout-assignment -vmi-to-vpto | FileCheck %s --check-prefix=LOWER

module {
  func.func @vmi_to_vpto_quant_matrix_f32_to_fp8_attrs(
      %src: !pto.ptr<f32, ub>,
      %inv_scale: f32,
      %dst: !pto.ptr<f8E4M3FN, ub>,
      %offset: index) {
    %wide = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
    %scale_vec = pto.vmi.vbrc %inv_scale
        : f32 -> !pto.vmi.vreg<256xf32>
    %scaled = pto.vmi.vmul %wide, %scale_vec
        : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
        -> !pto.vmi.vreg<256xf32>
    %packed = pto.vmi.vcvt %scaled {rounding = "H", saturate = "SAT"}
        : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf8E4M3FN>
    pto.vmi.vstore %packed, %dst[%offset]
        : !pto.vmi.vreg<256xf8E4M3FN>, !pto.ptr<f8E4M3FN, ub>
    return
  }
}

// ASSIGN-LABEL: func.func @vmi_to_vpto_quant_matrix_f32_to_fp8_attrs(
// ASSIGN: %[[PACKED:.*]] = pto.vmi.truncf
// ASSIGN-SAME: {rounding = "H", saturate = "SAT"}
// ASSIGN-SAME: -> !pto.vmi.vreg<256xf8E4M3FN

// LOWER-LABEL: func.func @vmi_to_vpto_quant_matrix_f32_to_fp8_attrs(
// LOWER: pto.vcvt
// LOWER-SAME: {part = "P0", rnd = "H", sat = "SAT"}
// LOWER: pto.vcvt
// LOWER-SAME: {part = "P1", rnd = "H", sat = "SAT"}
// LOWER: pto.vcvt
// LOWER-SAME: {part = "P2", rnd = "H", sat = "SAT"}
// LOWER: pto.vcvt
// LOWER-SAME: {part = "P3", rnd = "H", sat = "SAT"}
// LOWER-NOT: pto.vmi.
