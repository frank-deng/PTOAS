// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_relu_bf16_invalid(
      %source: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>) {
    %relu = pto.vmi.vrelu %source
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vrelu direct lowering requires physical vreg parts with b8/b16/b32 predicate masks and f16/f32 element type
// CHECK-SAME: pto.vrelu direct lowering supports only f16/f32 VMI floating-point element types
