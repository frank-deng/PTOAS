// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

// Rounding transparency: user-provided rounding attr on pto.vmi.vcvt must be
// carried through pto.vmi.truncf into the physical pto.vcvt's rnd attribute.
// Contract for bf16 -> f8E4M3FN allows "RAFZC"; here we exercise rnd = "A".

module {
  func.func @vmi_to_vpto_truncf_bf16_to_f8e4m3_rnd_a(
      %wide: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<256xf8E4M3FN> {
    %packed = pto.vmi.vcvt %wide {rounding = "A", saturate = "SAT"}
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf8E4M3FN, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%packed)
        : (!pto.vmi.vreg<128xf8E4M3FN, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xf8E4M3FN>
    return %p : !pto.vreg<256xf8E4M3FN>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_truncf_bf16_to_f8e4m3_rnd_a(
// CHECK: pto.vcvt {{.*}} {part = "EVEN", rnd = "A", sat = "SAT"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256xf8E4M3FN>
// CHECK: pto.vcvt {{.*}} {part = "ODD",  rnd = "A", sat = "SAT"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256xf8E4M3FN>
// CHECK: pto.vor
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
