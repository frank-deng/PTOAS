// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

// Contract: bf16 -> f8E5M2 requires rnd (allowed "RAFZC") + sat.  Default
// getTruncFRoundModeForResult(f8E5M2) is "R".

module {
  func.func @vmi_to_vpto_truncf_bf16_to_f8e5m2(
      %wide: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<256xf8E5M2> {
    %packed = pto.vmi.vcvt %wide
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf8E5M2, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%packed)
        : (!pto.vmi.vreg<128xf8E5M2, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xf8E5M2>
    return %p : !pto.vreg<256xf8E5M2>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_truncf_bf16_to_f8e5m2(
// CHECK: pto.vcvt {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256xf8E5M2>
// CHECK: pto.vcvt {{.*}} {part = "ODD",  rnd = "R", sat = "SAT"} : !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.vreg<256xf8E5M2>
// CHECK: pto.vor
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
