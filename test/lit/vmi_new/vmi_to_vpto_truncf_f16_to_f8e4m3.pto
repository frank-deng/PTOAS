// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

// EvenOdd factor branch: source layout deinterleaved=2 (2 physical parts),
// result layout contiguous (1 physical part), so vcvt lowering emits EVEN + ODD
// then vor-merges into one physical result vreg.  Contract:
//   f16 -> f8E4M3FN : requiresRnd=true, requiresSat=true, allowedRnd="RAFZC"

module {
  func.func @vmi_to_vpto_truncf_f16_to_f8e4m3(
      %even: !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>,
      %odd:  !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<256xf8E4M3FN> {
    %wide = pto.vmi.vadd %even, %odd
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
    %packed = pto.vmi.vcvt %wide
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf8E4M3FN, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%packed)
        : (!pto.vmi.vreg<128xf8E4M3FN, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xf8E4M3FN>
    return %p : !pto.vreg<256xf8E4M3FN>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_truncf_f16_to_f8e4m3(
// CHECK: %[[EVEN:.*]] = pto.vcvt {{.*}}, {{.*}} {part = "EVEN", rnd = "R", sat = "SAT"} : !pto.vreg<128xf16>, !pto.mask<b16> -> !pto.vreg<256xf8E4M3FN>
// CHECK: %[[ODD:.*]]  = pto.vcvt {{.*}}, {{.*}} {part = "ODD",  rnd = "R", sat = "SAT"} : !pto.vreg<128xf16>, !pto.mask<b16> -> !pto.vreg<256xf8E4M3FN>
// CHECK: pto.vor %[[EVEN]], %[[ODD]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
