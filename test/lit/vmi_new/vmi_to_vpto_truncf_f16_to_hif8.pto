// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

// Contract: f16 -> hif8 requires rnd (allowed "AH"); the lowering default
// getTruncFRoundModeForResult(hif8) is "A".  sat is required by contract.

module {
  func.func @vmi_to_vpto_truncf_f16_to_hif8(
      %wide: !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<256x!pto.hif8> {
    %packed = pto.vmi.vcvt %wide
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128x!pto.hif8, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%packed)
        : (!pto.vmi.vreg<128x!pto.hif8, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256x!pto.hif8>
    return %p : !pto.vreg<256x!pto.hif8>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_truncf_f16_to_hif8(
// CHECK: pto.vcvt {{.*}} {part = "EVEN", rnd = "A", sat = "SAT"} : !pto.vreg<128xf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "ODD",  rnd = "A", sat = "SAT"} : !pto.vreg<128xf16>, !pto.mask<b16> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vor
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
