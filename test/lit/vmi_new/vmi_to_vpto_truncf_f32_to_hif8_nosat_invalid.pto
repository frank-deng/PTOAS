// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

// f32 -> hif8 contract has requiresSat=true; a user-driven NOSAT is illegal
// and must be caught by the physical pto.vcvt verifier.

module {
  func.func @vmi_to_vpto_truncf_f32_to_hif8_nosat_invalid(
      %wide: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>)
      -> !pto.vreg<256x!pto.hif8> {
    %packed = pto.vmi.vcvt %wide {saturate = "NOSAT"}
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256x!pto.hif8, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%packed)
        : (!pto.vmi.vreg<256x!pto.hif8, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256x!pto.hif8>
    return %p : !pto.vreg<256x!pto.hif8>
  }
}

// CHECK: 'pto.vcvt' op requires sat attr for this vcvt type pair