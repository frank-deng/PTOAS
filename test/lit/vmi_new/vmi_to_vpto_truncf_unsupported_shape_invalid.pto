// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_truncf_unsupported_shape_invalid(
      %input: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>) {
    %narrow = pto.vmi.vcvt %input
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xf16, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.truncf supports f32/f16/bf16 source narrowing
