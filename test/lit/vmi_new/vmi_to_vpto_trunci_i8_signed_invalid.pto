// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_trunci_i32_to_i8_invalid(
      %wide: !pto.vmi.vreg<256xi32, #pto.vmi.layout<deinterleaved = 4>>)
      -> !pto.vreg<256xi8> {
    %narrow = pto.vmi.trunci %wide
        : !pto.vmi.vreg<256xi32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xi8, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%narrow)
        : (!pto.vmi.vreg<256xi8, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<256xi8>
    return %p : !pto.vreg<256xi8>
  }
}

// CHECK: VMI-UNSUPPORTED
// CHECK: pto.vmi.trunci supports integer deinterleaved source layouts
// CHECK: 8-bit integer narrowing requires unsigned i8 result
