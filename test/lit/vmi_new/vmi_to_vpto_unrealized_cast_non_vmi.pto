// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_unrealized_cast_non_vmi(
      %arg0: i32) -> f32 {
    %0 = builtin.unrealized_conversion_cast %arg0
        : i32 to f32
    return %0 : f32
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_unrealized_cast_non_vmi
// CHECK: builtin.unrealized_conversion_cast
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: pto.vmi.
