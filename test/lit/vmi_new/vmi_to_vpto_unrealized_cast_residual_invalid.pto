// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto 2>&1 | FileCheck %s

module {
  func.func @vmi_to_vpto_unrealized_cast_residual_invalid(
      %arg0: i32) {
    %0 = builtin.unrealized_conversion_cast %arg0
        : i32 to !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
    return
  }
}

// CHECK: VMI-RESIDUAL-OP: failed to convert all VMI ops/types to VPTO
