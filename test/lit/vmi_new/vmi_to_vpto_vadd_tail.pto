// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vadd tail: 100-lane f32 deinterleaved=2 → partial tail chunk lowering.

module {
  func.func @vadd_f32_tail(
      %a: !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %r = pto.vmi.vadd %a, %b
        : !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vadd_f32_tail(
// CHECK: pto.vadd
// CHECK: pto.vadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
