// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vbrc scalar broadcast: f32 scalar → f32 vector contiguous.

module {
  func.func @vbrc_f32_scalar(%s: f32)
      -> !pto.vreg<64xf32> {
    %r = pto.vmi.vbrc %s : f32 -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vbrc_f32_scalar(
// CHECK: pto.vdup
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
