// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_vcadd_f16(
      %source: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xf16> {
    %out = pto.vmi.vcadd %source, %mask {reassoc}
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>
    %p = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<128xf16>
    return %p : !pto.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcadd_f16(
// CHECK: pto.vcadd
// CHECK: pto.vadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
