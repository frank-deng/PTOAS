// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// group_reduce_addf→vcadd.  group_load and group_store kept (no new equivalents).
module {
  func.func @vmi_to_vpto_vcadd_group2_ops(
      %src: !pto.ptr<f32, ub>,
      %dst: !pto.ptr<f32, ub>,
      %row_stride: index,
      %mask: !pto.vmi.mask<512xb32, #pto.vmi.layout<contiguous>>) {
    %c0 = arith.constant 0 : index
    %v = pto.vmi.group_load %src[%c0], %row_stride
        {num_groups = 2}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<512xf32, #pto.vmi.layout<contiguous>>
    %r = pto.vmi.vcadd %v, %mask {group = 2, reassoc}
        : !pto.vmi.vreg<512xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<512xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>
    pto.vmi.group_store %r, %dst[%c0], %row_stride {num_groups = 2}
        : !pto.vmi.vreg<2xf32, #pto.vmi.layout<num_groups = 2, slots = 1>>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcadd_group2_ops(
// CHECK: pto.vlds
// CHECK: pto.vcgadd
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
