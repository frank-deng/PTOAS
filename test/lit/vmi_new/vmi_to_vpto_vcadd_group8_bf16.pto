// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// f16 group reduce → vcgadd.  V<128xf16> with group=8 → 8 groups of 16 lanes.
module {
  func.func @vmi_to_vpto_vcadd_group8_bf16(
      %source: !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xf16> {
    %out = pto.vmi.vcadd %source, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<8xf16, #pto.vmi.layout<num_groups = 8, slots = 8>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<8xf16, #pto.vmi.layout<num_groups = 8, slots = 8>>)
        -> !pto.vreg<128xf16>
    return %part : !pto.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcadd_group8_bf16(
// CHECK: pto.vcgadd %arg0, %arg1 : !pto.vreg<128xf16>, !pto.mask<b16> -> !pto.vreg<128xf16>
// CHECK: return
// CHECK-NOT: pto.vcadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
