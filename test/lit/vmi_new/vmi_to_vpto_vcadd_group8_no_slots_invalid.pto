// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// New vcadd with group=8 successfully lowers even without explicit slots=
// in the result layout (unlike old group_reduce_addf which required slots=8).
module {
  func.func @vcadd_group8_no_slots(
      %source: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xf32> {
    %out = pto.vmi.vcadd %source, %mask {group = 8, reassoc}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8>>)
        -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vcadd_group8_no_slots(
// CHECK: pto.vcgadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
