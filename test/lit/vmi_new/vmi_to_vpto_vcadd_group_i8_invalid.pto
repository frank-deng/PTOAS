// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-layout-assignment 2>&1 | FileCheck %s

// New vcadd accepts i8, but after two-stage lowering the old group_reduce_addi
// verifier rejects non-i32 element types for integer group reduction.
module {
  func.func @vcadd_group_i8_invalid(
      %source: !pto.vmi.vreg<256xi8>,
      %mask: !pto.vmi.mask<256xpred>) {
    %sum = pto.vmi.vcadd %source, %mask {group = 8}
        : !pto.vmi.vreg<256xi8>, !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<8xi8>
    return
  }
}

// CHECK: requires i32 accumulator element type
