// RUN: pto-test-opt %s -split-input-file -vmi-to-vpto | FileCheck %s

// New vcadd successfully lowers i32 partial-tail (old reduce_addi rejected this).
module {
  func.func @vmi_to_vpto_vcadd_i32_tail(
      %source: !pto.vmi.vreg<32xi32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<32xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %out = pto.vmi.vcadd %source, %mask
        : !pto.vmi.vreg<32xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<32xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<1xi32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %part : !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcadd_i32_tail(
// CHECK: pto.vcadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.

// -----

// New vcadd successfully lowers deinterleaved layouts (old reduce_addf rejected this).
module {
  func.func @vmi_to_vpto_vcadd_f32_deint(
      %source: !pto.vmi.vreg<64xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<64xf32> {
    %out = pto.vmi.vcadd %source, %mask {reassoc}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcadd_f32_deint(
// CHECK: pto.vcadd
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.

// -----

// New vcmin successfully lowers f16 partial-tail (old reduce_minf rejected this).
module {
  func.func @vmi_to_vpto_vcmin_f16_tail(
      %source: !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xf16> {
    %out = pto.vmi.vcmin %source, %mask
        : !pto.vmi.vreg<64xf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xf16, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<128xf16>
    return %part : !pto.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcmin_f16_tail(
// CHECK: pto.vcmin
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.

// -----

// New vcmax successfully lowers deinterleaved layouts (old reduce_maxf rejected this).
module {
  func.func @vmi_to_vpto_vcmax_f32_deint(
      %source: !pto.vmi.vreg<64xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> !pto.vreg<64xf32> {
    %out = pto.vmi.vcmax %source, %mask
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<1xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcmax_f32_deint(
// CHECK: pto.vcmax
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
