// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vci tail: 100-lane i32 contiguous iota from base 5.

module {
  func.func @vci_i32_tail(%base: i32)
      -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>) {
    %r = pto.vmi.vci %base : i32 -> !pto.vmi.vreg<100xi32, #pto.vmi.layout<contiguous>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xi32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>)
    return %p0, %p1 : !pto.vreg<64xi32>, !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vci_i32_tail(
// CHECK-COUNT-2: pto.vci
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
