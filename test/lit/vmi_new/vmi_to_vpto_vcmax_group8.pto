// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// Group max reduce → vcgmax.  V<64xf32> with group=8 → 8 groups of 8 lanes.
module {
  func.func @vmi_to_vpto_vcmax_group8(
      %source: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xf32> {
    %out = pto.vmi.vcmax %source, %mask {group = 8}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>
    %part = "pto.vmi.unpack"(%out)
        : (!pto.vmi.vreg<8xf32, #pto.vmi.layout<num_groups = 8, slots = 8>>)
        -> !pto.vreg<64xf32>
    return %part : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vcmax_group8(
// CHECK: pto.vcgmax %arg0, %arg1 : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xf32>
// CHECK: return
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
