// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcmp + vsel deinterleaved=2: fp compare with seed mask → vsel chain.

module {
  func.func @vcmp_vsel_f32_deint2(
      %a: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %t: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %f: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %seed: !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "lt"}
        : !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
    %r = pto.vmi.vsel %mask, %t, %f
        : !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vcmp_vsel_f32_deint2(
// CHECK: pto.vcmp
// CHECK: pto.vsel
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
