// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcmps: vector-scalar compare with seed mask.

module {
  func.func @vcmps_f32_lt(
      %src: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %scalar: f32,
      %seed: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>> {
    %m = pto.vmi.vcmps %src, %scalar, %seed {cmp = "lt"}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>, f32,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
    return %m : !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
  }

  func.func @vcmps_i32_slt(
      %src: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %scalar: i32,
      %seed: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>> {
    %m = pto.vmi.vcmps %src, %scalar, %seed {cmp = "slt"}
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>, i32,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
    return %m : !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
  }
}

// CHECK-LABEL: func.func @vcmps_f32_lt(
// CHECK: pto.vcmp
// CHECK-LABEL: func.func @vcmps_i32_slt(
// CHECK: pto.vcmp
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
