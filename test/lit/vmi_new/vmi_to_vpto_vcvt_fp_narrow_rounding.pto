// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt fp-narrowing with explicit rounding attribute {rounding = "H"}.

module {
  func.func @vcvt_fp_narrow_rounding(
      %even: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %odd: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<128xf16>,) {
    %src = "pto.vmi.pack"(%even, %odd)
        : (!pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
           !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
    %narrow = pto.vmi.vcvt %src {rounding = "H"}
        : !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%narrow)
        : (!pto.vmi.vreg<128xf16, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<128xf16>,)
    return %p0 : !pto.vreg<128xf16>
  }
}

// CHECK-LABEL: func.func @vcvt_fp_narrow_rounding(
// CHECK: %[[MASK:.*]] = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "EVEN", sat = "SAT"}
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "ODD", sat = "SAT"}
// CHECK: pto.vor
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
