// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt fp narrow tail: 100xf32 → 100xf16 deinterleaved=2.

module {
  func.func @vcvt_fp_narrow_tail(
      %a: !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<64xf16>, !pto.vreg<64xf16>) {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<100xf32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<100xf16, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xf16, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf16>, !pto.vreg<64xf16>)
    return %p0, %p1 : !pto.vreg<64xf16>, !pto.vreg<64xf16>
  }
}

// CHECK-LABEL: func.func @vcvt_fp_narrow_tail(
// CHECK: pto.vcvt
// CHECK: pto.vcvt
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
