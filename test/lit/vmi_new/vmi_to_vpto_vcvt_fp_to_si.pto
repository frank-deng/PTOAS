// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt fp-to-si (replaces fptosi): f32 -> i32. Regression guard for the
// VMILayoutAssignment direction-classification bug where srcFp && srcInt
// (instead of srcFp && dstInt) mis-routed FpToSi into IntNarrow.

module {
  func.func @vcvt_fp_to_si_f32_to_i32(
      %input: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vreg<64xi32>,) {
    %conv = pto.vmi.vcvt %input
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%conv)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xi32>,)
    return %p0 : !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vcvt_fp_to_si_f32_to_i32(
// CHECK: %[[MASK:.*]] = pto.pset_b32 "PAT_ALL" : !pto.mask<b32>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]]
// CHECK-SAME: !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<64xi32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
