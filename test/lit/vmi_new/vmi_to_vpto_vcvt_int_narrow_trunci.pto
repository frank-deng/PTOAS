// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt int narrow → trunci: 64xi32 → 64xi16 contiguous.

module {
  func.func @vcvt_int_narrow_contiguous(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi16> {
    %r = pto.vmi.vcvt %a
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi16>
    return %p0 : !pto.vreg<64xi16>
  }
}

// CHECK-LABEL: func.func @vcvt_int_narrow_contiguous(
// CHECK: pto.vcvt
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
