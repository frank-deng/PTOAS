// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt int-widening (replaces extsi/extui). Unsigned widen i8->i16 (EVEN/ODD)
// and i8->i32 (P0..P3) driven by {sign = "U"}.

module {
  func.func @vcvt_int_widen_u8_to_u16(
      %input: !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>)
      -> (!pto.vreg<128xui16>, !pto.vreg<128xui16>) {
    %wide = pto.vmi.vcvt %input {sign = "U"}
        : !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xui16, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%wide)
        : (!pto.vmi.vreg<256xui16, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<128xui16>, !pto.vreg<128xui16>)
    return %p0, %p1 : !pto.vreg<128xui16>, !pto.vreg<128xui16>
  }

  func.func @vcvt_int_widen_u8_to_u32(
      %input: !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>)
      -> (!pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>) {
    %wide = pto.vmi.vcvt %input {sign = "U"}
        : !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xui32, #pto.vmi.layout<deinterleaved = 4>>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%wide)
        : (!pto.vmi.vreg<256xui32, #pto.vmi.layout<deinterleaved = 4>>)
        -> (!pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.vreg<64xui32>
  }
}

// CHECK-LABEL: func.func @vcvt_int_widen_u8_to_u16(
// CHECK: %[[MASK:.*]] = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "EVEN"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<128xui16>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "ODD"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<128xui16>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast

// CHECK-LABEL: func.func @vcvt_int_widen_u8_to_u32(
// CHECK: %[[MASK:.*]] = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "P0"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<64xui32>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "P1"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<64xui32>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "P2"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<64xui32>
// CHECK: pto.vcvt %{{.*}}, %[[MASK]] {part = "P3"} : !pto.vreg<256xui8>, !pto.mask<b8> -> !pto.vreg<64xui32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
