// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vcvt int widen tail: 100xi16 → 100xi32 deinterleaved=2 signed.

module {
  func.func @vcvt_int_widen_tail(
      %a: !pto.vmi.vreg<100xi16, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>) {
    %r = pto.vmi.vcvt %a {sign = "signed"}
        : !pto.vmi.vreg<100xi16, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.vreg<100xi32, #pto.vmi.layout<deinterleaved = 2>>
    %p0, %p1 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xi32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xi32>, !pto.vreg<64xi32>)
    return %p0, %p1 : !pto.vreg<64xi32>, !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vcvt_int_widen_tail(
// CHECK: pto.vcvt
// CHECK: pto.vcvt
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
