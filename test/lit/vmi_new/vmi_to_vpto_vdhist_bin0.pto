// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_vdhist_bin0(
      %acc: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>,
      %source: !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<256xb8, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xui16> {
    %hist = pto.vmi.vdhist %acc, %source, %mask
        : !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xui8, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb8, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
    %result = "pto.vmi.unpack"(%hist)
        : (!pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<128xui16>
    return %result : !pto.vreg<128xui16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vdhist_bin0(
// CHECK-SAME: %[[ACC:[^,]+]]: !pto.vreg<128xui16>
// CHECK-SAME: %[[SRC:[^,]+]]: !pto.vreg<256xui8>
// CHECK-SAME: %[[MASK:[^)]+]]: !pto.mask<b8>
// CHECK-DAG: %[[BIN0:.*]] = arith.constant 0 : i32
// CHECK: %[[H:.*]] = pto.dhistv2 %[[ACC]], %[[SRC]], %[[MASK]], %[[BIN0]]
// CHECK-NOT: arith.constant 1 : i32
// CHECK: return %[[H]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
