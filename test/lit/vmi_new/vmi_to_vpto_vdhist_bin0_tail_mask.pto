// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_vdhist_bin0_tail_mask(
      %acc: !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>,
      %source: !pto.vmi.vreg<300xui8, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<300xb8, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<128xui16> {
    %hist = pto.vmi.vdhist %acc, %source, %mask
        : !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<300xui8, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<300xb8, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>
    %result = "pto.vmi.unpack"(%hist)
        : (!pto.vmi.vreg<128xui16, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<128xui16>
    return %result : !pto.vreg<128xui16>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vdhist_bin0_tail_mask(
// CHECK-SAME: %[[ACC:[^,]+]]: !pto.vreg<128xui16>
// CHECK-SAME: %[[SRC0:[^,]+]]: !pto.vreg<256xui8>
// CHECK-SAME: %[[SRC1:[^,]+]]: !pto.vreg<256xui8>
// CHECK-SAME: %[[MASK0:[^,]+]]: !pto.mask<b8>
// CHECK-SAME: %[[MASK1:[^)]+]]: !pto.mask<b8>
// CHECK-DAG: %[[BIN0:.*]] = arith.constant 0 : i32
// CHECK: %[[H0:.*]] = pto.dhistv2 %[[ACC]], %[[SRC0]], %[[MASK0]], %[[BIN0]]
// CHECK: %[[C44:.*]] = arith.constant 44 : i32
// CHECK: %[[TAIL:.*]], %{{.*}} = pto.plt_b8 %[[C44]] : i32 -> !pto.mask<b8>, i32
// CHECK: %[[ALL:.*]] = pto.pset_b8 "PAT_ALL" : !pto.mask<b8>
// CHECK: %[[MASK1_VALID:.*]] = pto.pand %[[MASK1]], %[[TAIL]], %[[ALL]]
// CHECK: %[[H1:.*]] = pto.dhistv2 %[[H0]], %[[SRC1]], %[[MASK1_VALID]], %[[BIN0]]
// CHECK-NOT: arith.constant 1 : i32
// CHECK: return %[[H1]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
