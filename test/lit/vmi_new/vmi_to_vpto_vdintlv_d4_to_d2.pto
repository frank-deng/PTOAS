// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_vdintlv_d4_to_d2(
      %a: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>,
      %b: !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>,
      %mask: !pto.vmi.mask<256xb32, #pto.vmi.layout<deinterleaved = 4>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vdintlv %a, %b, %mask
        : !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>,
          !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 4>>,
          !pto.vmi.mask<256xb32, #pto.vmi.layout<deinterleaved = 4>>
        -> !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>,
           !pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>
    %lo0, %lo1, %lo2, %lo3 = "pto.vmi.unpack"(%lo)
        : (!pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>,
            !pto.vreg<64xf32>, !pto.vreg<64xf32>)
    %hi0, %hi1, %hi2, %hi3 = "pto.vmi.unpack"(%hi)
        : (!pto.vmi.vreg<256xf32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>,
            !pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %lo0, %lo1, %lo2, %lo3, %hi0, %hi1, %hi2, %hi3
        : !pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>,
          !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vdintlv_d4_to_d2(
// CHECK-NOT: pto.vdintlv
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
