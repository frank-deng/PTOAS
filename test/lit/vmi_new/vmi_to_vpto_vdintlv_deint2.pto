// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vdintlv: deinterleave one vector into lo/hi parts with mask.

module {
  func.func @vdintlv_f32(
      %a: !pto.vmi.vreg<128xf32>,
      %mask: !pto.vmi.mask<128xpred>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vdintlv %a, %mask
        : !pto.vmi.vreg<128xf32>, !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
    %p0 = "pto.vmi.unpack"(%lo)
        : (!pto.vmi.vreg<64xf32>) -> !pto.vreg<64xf32>
    %p1 = "pto.vmi.unpack"(%hi)
        : (!pto.vmi.vreg<64xf32>) -> !pto.vreg<64xf32>
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vdintlv_f32(
// CHECK: pto.vdintlv
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
