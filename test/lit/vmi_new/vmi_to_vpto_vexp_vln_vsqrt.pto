// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vexp/vln/vsqrt/vrelu contiguous: math unary ops → VPTO.

module {
  func.func @vexp_f32(%a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32> {
    %r = pto.vmi.vexp %a : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r) : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
  func.func @vln_f32(%a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32> {
    %r = pto.vmi.vln %a : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r) : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
  func.func @vsqrt_f32(%a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32> {
    %r = pto.vmi.vsqrt %a : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r) : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
  func.func @vrelu_f32(%a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32> {
    %r = pto.vmi.vrelu %a : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>> -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r) : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vexp_f32(
// CHECK: pto.vexp
// CHECK-LABEL: func.func @vln_f32(
// CHECK: pto.vln
// CHECK-LABEL: func.func @vsqrt_f32(
// CHECK: pto.vsqrt
// CHECK-LABEL: func.func @vrelu_f32(
// CHECK: pto.vrelu
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
