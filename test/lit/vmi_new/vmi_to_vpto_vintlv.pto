// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmi_to_vpto_vintlv_f32(
      %a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vintlv %a, %b, %mask
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
           !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%lo)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    %p1 = "pto.vmi.unpack"(%hi)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vintlv_f32(
// CHECK: pto.vintlv
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
