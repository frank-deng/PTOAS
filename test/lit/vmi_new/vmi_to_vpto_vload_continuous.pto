// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vload continuous (default dist-mode), single 256B chunk f32 -> one VldsOp.

module {
  func.func @vload_continuous(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>,) {
    %r = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<64xf32>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xf32>) -> (!pto.vreg<64xf32>,)
    return %p0 : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_continuous(
// CHECK: pto.vlds %arg0[%arg1]
// CHECK-SAME: !pto.ptr<f32, ub> -> !pto.vreg<64xf32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
