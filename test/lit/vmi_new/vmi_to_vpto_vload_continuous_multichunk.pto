// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vload continuous, 256-lane f32 -> 4 physical VldsOp (multichunk fan-out).

module {
  func.func @vload_continuous_multichunk(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %r = pto.vmi.vload %src[%offset]
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
    %p0, %p1, %p2, %p3 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<256xf32>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1, %p2, %p3
        : !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_continuous_multichunk(
// CHECK-COUNT-4: pto.vlds %arg0[{{.*}}]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
