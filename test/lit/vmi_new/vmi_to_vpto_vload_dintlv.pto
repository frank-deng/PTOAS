// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vload with explicit {dist_mode = "dintlv"}: dual-return %lo, %hi.

module {
  func.func @vload_dintlv(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %lo, %hi = pto.vmi.vload %src[%offset] {dist_mode = "dintlv"}
        : !pto.ptr<f32, ub>
        -> !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>
    return %lo, %hi : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_dintlv(
// CHECK: %[[LO:.*]], %[[HI:.*]] = pto.vldsx2 %arg0[%arg1], "DINTLV_B32"
// CHECK: return %[[LO]], %[[HI]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
