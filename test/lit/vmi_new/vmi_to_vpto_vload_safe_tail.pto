// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vload safe tail: 100xf32 contiguous load from 128-element memref → two physical loads.

module {
  func.func @vload_safe_tail(%src: memref<128xf32>)
      -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>) {
    %c0 = arith.constant 0 : index
    %value = pto.vmi.vload %src[%c0] {dist_mode = "continuous"}
        : memref<128xf32> -> !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>
    %p0, %p1 = "pto.vmi.unpack"(%value)
        : (!pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>)
        -> (!pto.vreg<64xf32>, !pto.vreg<64xf32>)
    return %p0, %p1 : !pto.vreg<64xf32>, !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_safe_tail(
// CHECK: pto.vlds
// CHECK: pto.vlds
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
