// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vload unpack mode tail: 100xf32 unpack load with tail mask.

module {
  func.func @vload_unpack_tail(
      %src: !pto.ptr<f32, ub>, %offset: index)
      -> !pto.vreg<64xf32> {
    %r = pto.vmi.vload %src[%offset] {dist_mode = "unpack"}
        : !pto.ptr<f32, ub> -> !pto.vmi.vreg<100xf32>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<100xf32>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vload_unpack_tail(
// CHECK: pto.vldsx2
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
