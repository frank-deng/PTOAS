// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  func.func @vmull_contiguous_i32_64(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
           !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    return %low, %high
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
  }

  func.func @vmull_contiguous_i32_128(
      %a: !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
           !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>
    return %low, %high
        : !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xi32, #pto.vmi.layout<contiguous>>
  }

  func.func @vmull_contiguous_i32_256(
      %a: !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
           !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>
    return %low, %high
        : !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xi32, #pto.vmi.layout<contiguous>>
  }

  func.func @vmull_contiguous_ui32_64(
      %a: !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>)
      -> (!pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
           !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>
    return %low, %high
        : !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xui32, #pto.vmi.layout<contiguous>>
  }
}

// CHECK-LABEL: func.func @vmull_contiguous_i32_64(
// CHECK: %[[L64:.*]], %[[H64:.*]] = pto.vmull
// CHECK-SAME: !pto.vreg<64xi32>, !pto.vreg<64xi32>, !pto.mask<b32>
// CHECK-SAME: -> !pto.vreg<64xi32>, !pto.vreg<64xi32>
// CHECK-NOT: pto.vmull
// CHECK: return %[[L64]], %[[H64]]

// CHECK-LABEL: func.func @vmull_contiguous_i32_128(
// CHECK: %[[L128_0:.*]], %[[H128_0:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK: %[[L128_1:.*]], %[[H128_1:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK-NOT: pto.vmull
// CHECK: return %[[L128_0]], %[[L128_1]], %[[H128_0]], %[[H128_1]]

// CHECK-LABEL: func.func @vmull_contiguous_i32_256(
// CHECK: %[[L256_0:.*]], %[[H256_0:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK: %[[L256_1:.*]], %[[H256_1:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK: %[[L256_2:.*]], %[[H256_2:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK: %[[L256_3:.*]], %[[H256_3:.*]] = pto.vmull
// CHECK-SAME: !pto.mask<b32>
// CHECK-NOT: pto.vmull
// CHECK: return %[[L256_0]], %[[L256_1]], %[[L256_2]], %[[L256_3]], %[[H256_0]], %[[H256_1]], %[[H256_2]], %[[H256_3]]

// CHECK-LABEL: func.func @vmull_contiguous_ui32_64(
// CHECK: %[[LU:.*]], %[[HU:.*]] = pto.vmull
// CHECK-SAME: !pto.vreg<64xui32>, !pto.vreg<64xui32>, !pto.mask<b32>
// CHECK-SAME: -> !pto.vreg<64xui32>, !pto.vreg<64xui32>
// CHECK-NOT: pto.vmull
// CHECK: return %[[LU]], %[[HU]]
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
