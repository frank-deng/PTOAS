// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// Category C5: vmuls direct VMI→VPTO lowering (fp + int).

module {
  func.func @vmi_to_vpto_vmuls_f32(
      %a: !pto.vmi.vreg<64xf32>,
      %s: f32,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    %r = pto.vmi.vmuls %a, %s, %mask
        : !pto.vmi.vreg<64xf32>, f32, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }

  func.func @vmi_to_vpto_vmuls_i32(
      %a: !pto.vmi.vreg<64xi32>,
      %s: i32,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xi32> {
    %r = pto.vmi.vmuls %a, %s, %mask
        : !pto.vmi.vreg<64xi32>, i32, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xi32>
    return %r : !pto.vmi.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vmuls_f32(
// CHECK: pto.vmuls {{.*}}, {{.*}}, {{.*}} : !pto.vreg<64xf32>, f32, !pto.mask<b32> -> !pto.vreg<64xf32>
// CHECK-LABEL: func.func @vmi_to_vpto_vmuls_i32(
// CHECK: pto.vmuls {{.*}}, {{.*}}, {{.*}} : !pto.vreg<64xi32>, i32, !pto.mask<b32> -> !pto.vreg<64xi32>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
