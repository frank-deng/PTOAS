// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vneg + vabs contiguous: unary ops lowered to VPTO vneg/vabs.

module {
  func.func @vneg_f32_contiguous(
      %a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xf32> {
    %r = pto.vmi.vneg %a
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }

  func.func @vabs_f32_contiguous(
      %a: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xf32> {
    %r = pto.vmi.vabs %a
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }

  func.func @vabs_i32_contiguous(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %r = pto.vmi.vabs %a
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %p0 : !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vneg_f32_contiguous(
// CHECK: pto.vneg
// CHECK-LABEL: func.func @vabs_f32_contiguous(
// CHECK: pto.vabs
// CHECK-LABEL: func.func @vabs_i32_contiguous(
// CHECK: pto.vabs
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
