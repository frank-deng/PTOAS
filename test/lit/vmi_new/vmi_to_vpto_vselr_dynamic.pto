// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vselr: dynamic lane selection with index vector.

module {
  func.func @vselr_f32(
      %src: !pto.vmi.vreg<64xf32>,
      %index: !pto.vmi.vreg<64xi32>)
      -> !pto.vreg<64xf32> {
    %r = pto.vmi.vselr %src, %index
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xi32>
        -> !pto.vmi.vreg<64xf32>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xf32>) -> !pto.vreg<64xf32>
    return %p0 : !pto.vreg<64xf32>
  }
}

// CHECK-LABEL: func.func @vselr_f32(
// CHECK: pto.vselr
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
