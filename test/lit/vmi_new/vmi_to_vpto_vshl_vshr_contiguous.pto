// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vshl + vshr + vnot contiguous: shift and bitwise not.

module {
  func.func @vshl_i32_contiguous(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %r = pto.vmi.vshl %a, %b
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %p0 : !pto.vreg<64xi32>
  }

  func.func @vshr_i32_contiguous(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %r = pto.vmi.vshr %a, %b
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %p0 : !pto.vreg<64xi32>
  }

  func.func @vnot_i32_contiguous(
      %a: !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
      -> !pto.vreg<64xi32> {
    %r = pto.vmi.vnot %a
        : !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>
    %p0 = "pto.vmi.unpack"(%r)
        : (!pto.vmi.vreg<64xi32, #pto.vmi.layout<contiguous>>)
        -> !pto.vreg<64xi32>
    return %p0 : !pto.vreg<64xi32>
  }
}

// CHECK-LABEL: func.func @vshl_i32_contiguous(
// CHECK: pto.vshl
// CHECK-LABEL: func.func @vshr_i32_contiguous(
// CHECK: pto.vshr
// CHECK-LABEL: func.func @vnot_i32_contiguous(
// CHECK: pto.vnot
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
