// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// Category C5: vshrs direct VMI→VPTO lowering with explicit layout.
// Both data and mask carry contiguous layout so the verifier accepts them.
// VPTO vshrs requires i16 scalar and b16 mask.

module {
  func.func @vmi_to_vpto_vshrs_i16(
      %a: !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>,
      %s: i16,
      %mask: !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>)
      -> !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>> {
    %r = pto.vmi.vshrs %a, %s, %mask
        : !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>, i16,
          !pto.vmi.mask<64xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>
    return %r : !pto.vmi.vreg<64xi16, #pto.vmi.layout<contiguous>>
  }
}

// CHECK-LABEL: func.func @vmi_to_vpto_vshrs_i16(
// CHECK: pto.vshrs {{.*}}, {{.*}}, {{.*}} : !pto.vreg<128xi16>, i16, !pto.mask<b16> -> !pto.vreg<128xi16>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
