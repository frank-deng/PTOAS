// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vstore continuous (default), single value, no mask.

module {
  func.func @vstore_continuous(
      %src: !pto.ptr<f32, ub>, %offset: index) {
    %v = "pto.vmi.pack"() : () -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %v, %src[%offset]
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vstore_continuous(
// CHECK: pto.vsts %{{.*}}, %arg0[%arg1]
// CHECK-SAME: !pto.vreg<64xf32>, !pto.ptr<f32, ub>
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
