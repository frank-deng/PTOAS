// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// vstore {dist_mode = "dintlv"}: interleaved dual store with 2 values.

module {
  func.func @vstore_dintlv(
      %src: !pto.ptr<f32, ub>, %offset: index) {
    %lo = "pto.vmi.pack"() : () -> !pto.vmi.vreg<64xf32>
    %hi = "pto.vmi.pack"() : () -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %lo, %hi, %src[%offset] {dist_mode = "dintlv"}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vstore_dintlv(
// CHECK: pto.vstsx2 %{{.*}}, %{{.*}}, %arg0[%arg1], "INTLV_B32"
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
