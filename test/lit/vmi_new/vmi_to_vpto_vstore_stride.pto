// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vstore masked contiguous: masked f32 store → vsts with mask.

module {
  func.func @vstore_masked_f32(
      %val: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>) {
    pto.vmi.vstore %val, %dst[%offset], %mask {dist_mode = "continuous"}
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>, !pto.ptr<f32, ub>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK-LABEL: func.func @vstore_masked_f32(
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
