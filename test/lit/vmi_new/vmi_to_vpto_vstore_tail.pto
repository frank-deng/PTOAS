// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

// vstore tail: 100xf32 contiguous store → two physical stores.

module {
  func.func @vstore_contiguous_tail(
      %val: !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>,
      %dst: !pto.ptr<f32, ub>,
      %offset: index) {
    pto.vmi.vstore %val, %dst[%offset] {dist_mode = "continuous"}
        : !pto.vmi.vreg<100xf32, #pto.vmi.layout<contiguous>>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK-LABEL: func.func @vstore_contiguous_tail(
// CHECK: pto.vsts
// CHECK: pto.vsts
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
