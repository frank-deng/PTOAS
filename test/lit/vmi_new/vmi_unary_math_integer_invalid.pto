// RUN: not pto-test-opt %s -split-input-file 2>&1 | FileCheck %s

module {
  func.func @vmi_sqrt_integer_invalid(%value: !pto.vmi.vreg<128xi32>) {
    %sqrt = pto.vmi.vsqrt %value
        : !pto.vmi.vreg<128xi32> -> !pto.vmi.vreg<128xi32>
    return
  }
}

// CHECK: 'pto.vmi.vsqrt' op requires floating-point-like VMI element type

// -----

module {
  func.func @vmi_exp_integer_invalid(%value: !pto.vmi.vreg<128xi32>) {
    %exp = pto.vmi.vexp %value
        : !pto.vmi.vreg<128xi32> -> !pto.vmi.vreg<128xi32>
    return
  }
}

// CHECK: 'pto.vmi.vexp' op requires floating-point-like VMI element type

// -----

module {
  func.func @vmi_ln_integer_invalid(%value: !pto.vmi.vreg<128xi32>) {
    %ln = pto.vmi.vln %value
        : !pto.vmi.vreg<128xi32> -> !pto.vmi.vreg<128xi32>
    return
  }
}

// CHECK: 'pto.vmi.vln' op requires floating-point-like VMI element type

// -----

module {
  func.func @vmi_relu_integer_invalid(%value: !pto.vmi.vreg<128xi32>) {
    %relu = pto.vmi.vrelu %value
        : !pto.vmi.vreg<128xi32> -> !pto.vmi.vreg<128xi32>
    return
  }
}

// CHECK: 'pto.vmi.vrelu' op requires floating-point-like VMI element type
