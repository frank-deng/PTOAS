// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vcadd: floating-point reduction without reassoc attr → error.

module {
  func.func @vcadd_fp_no_reassoc(
      %src: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<1xf32> {
    // CHECK: floating add-reduction requires reassoc attr
    %r = pto.vmi.vcadd %src, %mask
        : !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<1xf32>
    return %r : !pto.vmi.vreg<1xf32>
  }
}
