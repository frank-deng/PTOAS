// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s
// RUN: not pto-test-opt %s -vmi-lower-unified-to-legacy 2>&1 | FileCheck %s

// vcmax: group count must divide source lane count.

module {
  func.func @vcmax_group_no_divide(
      %src: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<3xf32> {
    // CHECK: error: 'pto.vmi.vcmax' op group count 3 must divide source lane count 64
    %r = pto.vmi.vcmax %src, %mask {group = 3}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<3xf32>
    return %r : !pto.vmi.vreg<3xf32>
  }
}
