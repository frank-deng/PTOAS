// RUN: pto-test-opt %s -vmi-to-vpto | FileCheck %s

module {
  // CHECK-LABEL: func.func @vcmp_f32_lt_deintlv
  func.func @vcmp_f32_lt_deintlv(
      %a: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %seed: !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.mask<b32>, !pto.mask<b32>) {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "lt"}
        : !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
    %m0, %m1 = "pto.vmi.unpack"(%mask)
        : (!pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.mask<b32>, !pto.mask<b32>)
    return %m0, %m1 : !pto.mask<b32>, !pto.mask<b32>
  }
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "lt"
  // CHECK-SAME: !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.mask<b32>
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "lt"
  // CHECK-SAME: !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.mask<b32>

  // CHECK-LABEL: func.func @vcmp_i32_sge_deintlv
  func.func @vcmp_i32_sge_deintlv(
      %a: !pto.vmi.vreg<128xi32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<128xi32, #pto.vmi.layout<deinterleaved = 2>>,
      %seed: !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.mask<b32>, !pto.mask<b32>) {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "sge"}
        : !pto.vmi.vreg<128xi32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xi32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
    %m0, %m1 = "pto.vmi.unpack"(%mask)
        : (!pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.mask<b32>, !pto.mask<b32>)
    return %m0, %m1 : !pto.mask<b32>, !pto.mask<b32>
  }
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "ge"
  // CHECK-SAME: !pto.vreg<64xi32>, !pto.vreg<64xi32>, !pto.mask<b32> -> !pto.mask<b32>
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "ge"
  // CHECK-SAME: !pto.vreg<64xi32>, !pto.vreg<64xi32>, !pto.mask<b32> -> !pto.mask<b32>

  // CHECK-LABEL: func.func @vcmp_bf16_eq_contig
  func.func @vcmp_bf16_eq_contig(
      %a: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
      %seed: !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>)
      -> !pto.mask<b16> {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "eq"}
        : !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<128xbf16, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>
    %part = "pto.vmi.unpack"(%mask)
        : (!pto.vmi.mask<128xb16, #pto.vmi.layout<contiguous>>)
        -> !pto.mask<b16>
    return %part : !pto.mask<b16>
  }
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "eq"
  // CHECK-SAME: !pto.vreg<128xbf16>, !pto.vreg<128xbf16>, !pto.mask<b16> -> !pto.mask<b16>

  // CHECK-LABEL: func.func @vcmp_f32_ordered_olt
  func.func @vcmp_f32_ordered_olt(
      %a: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %b: !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
      %seed: !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
      -> (!pto.mask<b32>, !pto.mask<b32>) {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "olt"}
        : !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.vreg<128xf32, #pto.vmi.layout<deinterleaved = 2>>,
          !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
        -> !pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>
    %m0, %m1 = "pto.vmi.unpack"(%mask)
        : (!pto.vmi.mask<128xb32, #pto.vmi.layout<deinterleaved = 2>>)
        -> (!pto.mask<b32>, !pto.mask<b32>)
    return %m0, %m1 : !pto.mask<b32>, !pto.mask<b32>
  }
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "lt"
  // CHECK-SAME: !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.mask<b32>
  // CHECK: pto.vcmp {{.*}}, {{.*}}, {{.*}}, "lt"
  // CHECK-SAME: !pto.vreg<64xf32>, !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.mask<b32>

  // CHECK-NOT: pto.vmi.
  // CHECK-NOT: !pto.vmi.
}
