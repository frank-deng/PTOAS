// RUN: not pto-test-opt %s -vmi-to-vpto 2>&1 | FileCheck %s

module {
  // CHECK: VMI{{-}}UNSUPPORTED{{:}} pto.vmi.vcmp direct lowering requires f16/bf16/f32
  func.func @vcmp_f8_invalid(
      %a: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %b: !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
      %seed: !pto.vmi.mask<256xb8, #pto.vmi.layout<contiguous>>) {
    %mask = pto.vmi.vcmp %a, %b, %seed {cmp = "lt"}
        : !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.vreg<256xf8E4M3FN, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<256xb8, #pto.vmi.layout<contiguous>>
        -> !pto.vmi.mask<256xb8, #pto.vmi.layout<contiguous>>
    return
  }
}
