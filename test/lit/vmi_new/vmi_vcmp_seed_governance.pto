// RUN: pto-test-opt %s -vmi-layout-assignment -vmi-to-vpto | FileCheck %s

// Cross-feature: vcmp seed governance — seed[i]=0 ⇒ result[i]=0 regardless of comparison.
// Test all-active seed case.

module {
  // CHECK-LABEL: func.func @vcmp_seed_all_active
  func.func @vcmp_seed_all_active(
      %a: !pto.vmi.vreg<64xf32>,
      %b: !pto.vmi.vreg<64xf32>,
      %seed: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.mask<64xpred> {
    %r = pto.vmi.vcmp %a, %b, %seed {cmp = "oeq"}
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred>
        -> !pto.vmi.mask<64xpred>
    return %r : !pto.vmi.mask<64xpred>
  }
}
// CHECK-NOT: pto.vmi.
// CHECK-NOT: !pto.vmi.
// CHECK-NOT: unrealized_conversion_cast
