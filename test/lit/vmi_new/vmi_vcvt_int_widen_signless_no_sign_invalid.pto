// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// Signless integer widening without an explicit {sign} attribute is rejected.

module {
  func.func @vcvt_int_widen_signless_no_sign_invalid(
      %source: !pto.vmi.vreg<256xi8>) {
    %result = pto.vmi.vcvt %source
        : !pto.vmi.vreg<256xi8> -> !pto.vmi.vreg<256xi16>
    return
  }
}

// CHECK: 'sign' attribute ('S' or 'U') is required for int-widening conversions with a signless integer source element type
