// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vcvt_lane_mismatch_invalid(%source: !pto.vmi.vreg<128xf32>) {
    %result = pto.vmi.vcvt %source
        : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<64xf16>
    return
  }
}

// CHECK: requires source and result logical lane counts to match
