// RUN: pto-test-opt %s -vmi-lower-unified-to-legacy | FileCheck %s

// lowerVCvt must forward the saturate attribute (or its absence) from
// pto.vmi.vcvt down to the legacy pto.vmi.truncf / pto.vmi.trunci /
// pto.vmi.fptosi op created for the corresponding CvtDirection.  All three
// directions x {SAT, NOSAT, absent} = 9 sub-cases are exercised below.
//
// The "absent" cases use a whole-line CHECK pattern to assert that no
// saturate attr shows up between the operand and the operand types.

module {
  // ---- FpNarrow (f32 -> f16) ----

  func.func @fpnarrow_sat(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xf16> {
    %result = pto.vmi.vcvt %source {saturate = "SAT"}
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf16>
    return %result : !pto.vmi.vreg<64xf16>
  }

  func.func @fpnarrow_nosat(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xf16> {
    %result = pto.vmi.vcvt %source {saturate = "NOSAT"}
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf16>
    return %result : !pto.vmi.vreg<64xf16>
  }

  func.func @fpnarrow_default(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xf16> {
    %result = pto.vmi.vcvt %source
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf16>
    return %result : !pto.vmi.vreg<64xf16>
  }

  // ---- IntNarrow (si32 -> si16) ----

  func.func @intnarrow_sat(%source: !pto.vmi.vreg<64xsi32>)
      -> !pto.vmi.vreg<64xsi16> {
    %result = pto.vmi.vcvt %source {saturate = "SAT"}
        : !pto.vmi.vreg<64xsi32> -> !pto.vmi.vreg<64xsi16>
    return %result : !pto.vmi.vreg<64xsi16>
  }

  func.func @intnarrow_nosat(%source: !pto.vmi.vreg<64xsi32>)
      -> !pto.vmi.vreg<64xsi16> {
    %result = pto.vmi.vcvt %source {saturate = "NOSAT"}
        : !pto.vmi.vreg<64xsi32> -> !pto.vmi.vreg<64xsi16>
    return %result : !pto.vmi.vreg<64xsi16>
  }

  func.func @intnarrow_default(%source: !pto.vmi.vreg<64xsi32>)
      -> !pto.vmi.vreg<64xsi16> {
    %result = pto.vmi.vcvt %source
        : !pto.vmi.vreg<64xsi32> -> !pto.vmi.vreg<64xsi16>
    return %result : !pto.vmi.vreg<64xsi16>
  }

  // ---- FpToSi (f32 -> si32) ----

  func.func @fptosi_sat(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xsi32> {
    %result = pto.vmi.vcvt %source {saturate = "SAT"}
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xsi32>
    return %result : !pto.vmi.vreg<64xsi32>
  }

  func.func @fptosi_nosat(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xsi32> {
    %result = pto.vmi.vcvt %source {saturate = "NOSAT"}
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xsi32>
    return %result : !pto.vmi.vreg<64xsi32>
  }

  func.func @fptosi_default(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xsi32> {
    %result = pto.vmi.vcvt %source
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xsi32>
    return %result : !pto.vmi.vreg<64xsi32>
  }
}

// CHECK-LABEL: func.func @fpnarrow_sat(
// CHECK: pto.vmi.truncf
// CHECK-SAME: saturate = "SAT"

// CHECK-LABEL: func.func @fpnarrow_nosat(
// CHECK: pto.vmi.truncf
// CHECK-SAME: saturate = "NOSAT"

// CHECK-LABEL: func.func @fpnarrow_default(
// CHECK: pto.vmi.truncf %{{[^{]+}} : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xf16>

// CHECK-LABEL: func.func @intnarrow_sat(
// CHECK: pto.vmi.trunci
// CHECK-SAME: saturate = "SAT"

// CHECK-LABEL: func.func @intnarrow_nosat(
// CHECK: pto.vmi.trunci
// CHECK-SAME: saturate = "NOSAT"

// CHECK-LABEL: func.func @intnarrow_default(
// CHECK: pto.vmi.trunci %{{[^{]+}} : !pto.vmi.vreg<64xsi32> -> !pto.vmi.vreg<64xsi16>

// CHECK-LABEL: func.func @fptosi_sat(
// CHECK: pto.vmi.fptosi
// CHECK-SAME: saturate = "SAT"

// CHECK-LABEL: func.func @fptosi_nosat(
// CHECK: pto.vmi.fptosi
// CHECK-SAME: saturate = "NOSAT"

// CHECK-LABEL: func.func @fptosi_default(
// CHECK: pto.vmi.fptosi %{{[^{]+}} : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xsi32>