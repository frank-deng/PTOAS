// RUN: pto-test-opt %s | FileCheck %s

// IntNarrow accepts saturate = "NOSAT" (new user-driven non-saturating request).

module {
  func.func @vmi_vcvt_saturate_nosat_intnarrow(%source: !pto.vmi.vreg<64xsi32>)
      -> !pto.vmi.vreg<64xsi16> {
    %result = pto.vmi.vcvt %source {saturate = "NOSAT"}
        : !pto.vmi.vreg<64xsi32> -> !pto.vmi.vreg<64xsi16>
    return %result : !pto.vmi.vreg<64xsi16>
  }
}

// CHECK-LABEL: func.func @vmi_vcvt_saturate_nosat_intnarrow(
// CHECK: pto.vmi.vcvt
// CHECK-SAME: saturate = "NOSAT"