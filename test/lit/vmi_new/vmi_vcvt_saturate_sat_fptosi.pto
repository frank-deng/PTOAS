// RUN: pto-test-opt %s | FileCheck %s

// FpToSi also accepts an explicit saturate = "SAT" (redundant but must not be
// rejected under the new semantics).

module {
  func.func @vmi_vcvt_saturate_sat_fptosi(%source: !pto.vmi.vreg<64xf32>)
      -> !pto.vmi.vreg<64xsi32> {
    %result = pto.vmi.vcvt %source {saturate = "SAT"}
        : !pto.vmi.vreg<64xf32> -> !pto.vmi.vreg<64xsi32>
    return %result : !pto.vmi.vreg<64xsi32>
  }
}

// CHECK-LABEL: func.func @vmi_vcvt_saturate_sat_fptosi(
// CHECK: pto.vmi.vcvt
// CHECK-SAME: saturate = "SAT"