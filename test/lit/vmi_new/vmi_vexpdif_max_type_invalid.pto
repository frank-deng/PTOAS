// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vexpdif: max element type must be f32 (hardware constraint).

module {
  func.func @vexpdif_max_not_f32(
      %x: !pto.vmi.vreg<64xf32>,
      %max: !pto.vmi.vreg<64xf16>,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    // CHECK: error: 'pto.vmi.vexpdif' op requires max element type to be f32
    %r = pto.vmi.vexpdif %x, %max, %mask
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf16>, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
