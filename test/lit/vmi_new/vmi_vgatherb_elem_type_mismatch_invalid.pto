// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vgatherb: requires u32 offsets matching source/result shape.

module {
  func.func @vgatherb_offsets_not_u32(
      %src: !pto.ptr<f32, ub>,
      %offset: index,
      %indices: !pto.vmi.vreg<64xi16>,
      %mask: !pto.vmi.mask<64xb32>)
      -> !pto.vmi.vreg<64xf32> {
    // CHECK: requires u32 offsets element type
    %r = pto.vmi.vgatherb %src[%offset], %indices, %mask
        : !pto.ptr<f32, ub>, !pto.vmi.vreg<64xi16>, !pto.vmi.mask<64xb32>
        -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
