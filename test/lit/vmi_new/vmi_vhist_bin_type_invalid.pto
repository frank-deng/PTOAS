// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vhist: bin_idx element type must be ui8, ui16, or ui32.

module {
  func.func @vhist_bad_bin_type(
      %bin_idx: !pto.vmi.vreg<256xi64>,
      %mask: !pto.vmi.mask<256xpred>)
      -> !pto.vmi.vreg<256xi16> {
    // CHECK: error: 'pto.vmi.vhist' op requires bin_idx element type to be ui8, ui16, or ui32
    %r = pto.vmi.vhist %bin_idx, %mask
        : !pto.vmi.vreg<256xi64>, !pto.vmi.mask<256xpred> -> !pto.vmi.vreg<256xi16>
    return %r : !pto.vmi.vreg<256xi16>
  }
}
