// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vlrelu: slope scalar type must match vector element type.
// f32 element with f16 slope → error.

module {
  func.func @vlrelu_slope_mismatch(
      %x: !pto.vmi.vreg<64xf32>,
      %slope: f16,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    // CHECK: requires slope scalar type to match vector element type
    %r = "pto.vmi.vlrelu"(%x, %slope, %mask)
        : (!pto.vmi.vreg<64xf32>, f16, !pto.vmi.mask<64xpred>)
        -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
