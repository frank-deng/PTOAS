// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vmula: acc, lhs, rhs, and result must have identical VMI vreg types.

module {
  func.func @vmula_type_mismatch(
      %acc: !pto.vmi.vreg<64xf32>,
      %lhs: !pto.vmi.vreg<64xf16>,
      %rhs: !pto.vmi.vreg<64xf32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> !pto.vmi.vreg<64xf32> {
    // CHECK: error: 'pto.vmi.vmula' op requires acc, lhs, rhs, and result to have identical VMI vreg types
    %r = pto.vmi.vmula %acc, %lhs, %rhs, %mask
        : !pto.vmi.vreg<64xf32>, !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<64xf32>, !pto.vmi.mask<64xpred> -> !pto.vmi.vreg<64xf32>
    return %r : !pto.vmi.vreg<64xf32>
  }
}
