// RUN: pto-test-opt %s | FileCheck %s

module {
  func.func @vmull_i32_64(
      %a: !pto.vmi.vreg<64xi32>,
      %b: !pto.vmi.vreg<64xi32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> (!pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>,
          !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>
    return %low, %high : !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>
  }

  func.func @vmull_i32_128_zero(
      %a: !pto.vmi.vreg<128xi32>,
      %b: !pto.vmi.vreg<128xi32>,
      %mask: !pto.vmi.mask<128xpred>)
      -> (!pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask {pmode = "zero"}
        : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>,
          !pto.vmi.mask<128xpred>
        -> !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
    return %low, %high : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
  }

  func.func @vmull_i32_256(
      %a: !pto.vmi.vreg<256xi32>,
      %b: !pto.vmi.vreg<256xi32>,
      %mask: !pto.vmi.mask<256xpred>)
      -> (!pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>,
          !pto.vmi.mask<256xpred>
        -> !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
    return %low, %high : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
  }

  func.func @vmull_ui32_64(
      %a: !pto.vmi.vreg<64xui32>,
      %b: !pto.vmi.vreg<64xui32>,
      %mask: !pto.vmi.mask<64xpred>)
      -> (!pto.vmi.vreg<64xui32>, !pto.vmi.vreg<64xui32>) {
    %low, %high = pto.vmi.vmull %a, %b, %mask
        : !pto.vmi.vreg<64xui32>, !pto.vmi.vreg<64xui32>,
          !pto.vmi.mask<64xpred>
        -> !pto.vmi.vreg<64xui32>, !pto.vmi.vreg<64xui32>
    return %low, %high : !pto.vmi.vreg<64xui32>, !pto.vmi.vreg<64xui32>
  }
}

// CHECK-LABEL: func.func @vmull_i32_64(
// CHECK: %[[LOW64:.*]], %[[HIGH64:.*]] = pto.vmi.vmull
// CHECK-SAME: -> !pto.vmi.vreg<64xi32>, !pto.vmi.vreg<64xi32>
// CHECK: return %[[LOW64]], %[[HIGH64]]
// CHECK-LABEL: func.func @vmull_i32_128_zero(
// CHECK: pto.vmi.vmull
// CHECK-SAME: pmode = "zero"
// CHECK-SAME: -> !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
// CHECK-LABEL: func.func @vmull_i32_256(
// CHECK: pto.vmi.vmull
// CHECK-SAME: -> !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
// CHECK-LABEL: func.func @vmull_ui32_64(
// CHECK: pto.vmi.vmull
// CHECK-SAME: -> !pto.vmi.vreg<64xui32>, !pto.vmi.vreg<64xui32>
