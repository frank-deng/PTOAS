// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vscatter: offsets must be signless or unsigned 32-bit integer.

module {
  func.func @vscatter_offsets_not_u32(
      %dst: !pto.ptr<f32, ub>,
      %offset: index,
      %value: !pto.vmi.vreg<64xf32>,
      %indices: !pto.vmi.vreg<64xi16>,
      %mask: !pto.vmi.mask<64xb32>)
      -> !pto.ptr<f32, ub> {
    // CHECK: requires signless or unsigned 32-bit integer offsets
    %r = pto.vmi.vscatter %value, %dst[%offset], %indices, %mask
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>, !pto.vmi.vreg<64xi16>, !pto.vmi.mask<64xb32>
        -> !pto.ptr<f32, ub>
    return %r : !pto.ptr<f32, ub>
  }
}
