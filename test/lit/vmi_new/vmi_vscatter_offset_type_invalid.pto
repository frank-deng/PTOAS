// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vmi_vscatter_offset_type_invalid(
      %value: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %dst: !pto.ptr<f32, ub>,
      %offsets: !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
      %mask: !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>) {
    pto.vmi.vscatter %value, %dst, %offsets, %mask
        : !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.ptr<f32, ub>,
          !pto.vmi.vreg<64xf32, #pto.vmi.layout<contiguous>>,
          !pto.vmi.mask<64xb32, #pto.vmi.layout<contiguous>>
    return
  }
}

// CHECK: requires signless or unsigned 32-bit integer offsets
