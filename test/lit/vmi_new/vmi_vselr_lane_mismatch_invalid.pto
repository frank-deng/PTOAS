// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

// vselr: index lane count must match result lane count.

module {
  func.func @vselr_index_lane_mismatch(
      %src: !pto.vmi.vreg<64xf16>,
      %idx: !pto.vmi.vreg<8xi16>)
      -> !pto.vmi.vreg<4xf16> {
    // CHECK: error: 'pto.vmi.vselr' op requires index lane count to match result lane count
    %r = pto.vmi.vselr %src, %idx
        : !pto.vmi.vreg<64xf16>, !pto.vmi.vreg<8xi16> -> !pto.vmi.vreg<4xf16>
    return %r : !pto.vmi.vreg<4xf16>
  }
}
