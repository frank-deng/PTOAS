// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vstore_bad_pmode_invalid(
      %src: !pto.ptr<f32, ub>, %offset: index) {
    %v = "pto.vmi.pack"() : () -> !pto.vmi.vreg<64xf32>
    pto.vmi.vstore %v, %src[%offset] {pmode = "x"}
        : !pto.vmi.vreg<64xf32>, !pto.ptr<f32, ub>
    return
  }
}

// CHECK: invalid pmode: "x"
