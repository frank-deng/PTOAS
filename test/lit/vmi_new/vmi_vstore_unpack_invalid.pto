// RUN: not ptoas --emit-pto-ir %s 2>&1 | FileCheck %s

module {
  func.func @vstore_unpack_invalid(
      %src: !pto.ptr<i8, ub>, %offset: index) {
    %v = "pto.vmi.pack"() : () -> !pto.vmi.vreg<128xi16>
    pto.vmi.vstore %v, %src[%offset] {dist_mode = "unpack"}
        : !pto.vmi.vreg<128xi16>, !pto.ptr<i8, ub>
    return
  }
}

// CHECK: is not valid for vstore
