// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --enable-vpto-soft-postupdate --emit-vpto %s -o - | FileCheck %s

// Already post-update: should not transform again.
// CHECK-LABEL: func.func @already_post
// CHECK: pto.vlds {{.*}} -> !pto.vreg<64xf32>, !pto.ptr<f32,
// CHECK-NOT: iter_args({{.*}}!pto.ptr{{.*}}!pto.ptr

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @already_post(%input: !pto.ptr<f32, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c64 = arith.constant 64 : index
    %c1024 = arith.constant 1024 : index
    %c0_i64 = arith.constant 0 : i64
    %c1024_i32 = arith.constant 1024 : i32

    %ub_in = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>

    pto.vecscope {
      %_:2 = scf.for %iv = %c0 to %c1024 step %c64
          iter_args(%remaining = %c1024_i32, %ptr = %ub_in)
          -> (i32, !pto.ptr<f32, ub>) {
        %mask, %next = pto.plt_b32 %remaining : i32 -> !pto.mask<b32>, i32
        %vec, %updated = pto.vlds %ptr[%c64] {dist = "NORM"} : !pto.ptr<f32, ub> -> !pto.vreg<64xf32>, !pto.ptr<f32, ub>
        scf.yield %next, %updated : i32, !pto.ptr<f32, ub>
      }
    }
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
