// Test Bin1LCountMode: nonVLAligned + totalRepeats > 255.
// 41x200 f32 — nonVLAligned=true, totalRepeats=257>255 → count mode.

// RUN: ( mkdir -p %T && ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=pto-lower-to-ubuf-ops 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @lower_tadd_chunked_tail() attributes {pto.aicore} {
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tadd ins(%src0, %src1 : !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%dst : !pto.tile_buf<loc=vec, dtype=f32, rows=41, cols=200, v_row=41, v_col=200, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// Count mode — no scf.for, no head+tail norm mode
// CHECK-LABEL: func.func @lower_tadd_chunked_tail
// CHECK: pto.ub.set_mask_count
// CHECK: pto.ub.set_mask
// CHECK: pto.ub.vadd
// CHECK: pto.ub.set_mask_norm
// CHECK: pto.ub.set_mask %c-1_i64, %c0
// CHECK-NOT: scf.for
// CHECK-NOT: pto.tadd
