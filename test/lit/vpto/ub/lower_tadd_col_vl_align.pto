// Test Bin2LNormModeColVLAlign: partial valid columns, row-by-row, VL-aligned.
// 2x128 f32, valid=2x32 — cols=128, vCols=32.
// epr=32: normColRepeat=128/32=4, vRows=2 < normColRepeat+1=5, vCols%epr=32%32=0 → ColVLAlign.
// headRepeats=vCols/epr=1, row loop with stride=8.

// RUN: ( mkdir -p %T && ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=pto-lower-to-ubuf-ops 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @lower_tadd_col_vl_align() attributes {pto.aicore} {
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %src1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tadd ins(%src0, %src1 : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%dst : !pto.tile_buf<loc=vec, dtype=f32, rows=2, cols=128, v_row=2, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// Row-by-row: scf.for 2 iterations, vadd(repeat=1, stride=8) per row, no masking.
// CHECK-LABEL: func.func @lower_tadd_col_vl_align
// CHECK: scf.for
// CHECK: pto.addptr
// CHECK: pto.ub.vadd
// CHECK-NOT: pto.ub.set_mask %c
// CHECK-NOT: pto.tadd
