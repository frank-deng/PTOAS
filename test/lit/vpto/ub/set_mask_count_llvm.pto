// Test that pto.ub.set_mask_count and pto.ub.set_mask_norm lower to
// SBITSET1 / SBITSET0 on CTRL register bit 56 (matching CCE reference).

// RUN: ( mkdir -p %T && ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

// CHECK-LABEL: llvm.func @set_mask_count_llvm_mix_aiv
// CHECK: llvm.call @llvm.hivm.SBITSET1
// CHECK: llvm.call @llvm.hivm.SET.CTRL

// CHECK-LABEL: llvm.func @set_mask_norm_llvm_mix_aiv
// CHECK: llvm.call @llvm.hivm.SBITSET0
// CHECK: llvm.call @llvm.hivm.SET.CTRL

// CHECK-LABEL: llvm.func @count_mode_sequence_mix_aiv
// CHECK: llvm.call @llvm.hivm.SBITSET1
// CHECK: llvm.call @llvm.hivm.SET.CTRL
// CHECK: llvm.call @llvm.hivm.MOVEMASK
// CHECK: llvm.call @llvm.hivm.MOVEMASK
// CHECK: llvm.call @llvm.hivm.SBITSET0
// CHECK: llvm.call @llvm.hivm.SET.CTRL

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {

  func.func @set_mask_count_llvm() attributes {pto.aicore} {
    pto.ub.set_mask_count
    return
  }

  func.func @set_mask_norm_llvm() attributes {pto.aicore} {
    pto.ub.set_mask_norm
    return
  }

  func.func @count_mode_sequence() attributes {pto.aicore} {
    pto.ub.set_mask_count
    %c0 = arith.constant 0 : i64
    %c42 = arith.constant 42 : i64
    pto.ub.set_mask %c42, %c0 : i64, i64
    pto.ub.set_mask_norm
    return
  }
}
