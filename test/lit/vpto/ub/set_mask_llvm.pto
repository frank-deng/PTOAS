// Test that pto.ub.set_mask is lowered to two llvm.hivm.MOVEMASK calls
// per CCE expansion: movemask(0, mask0); movemask(1, mask1).

// RUN: ( mkdir -p %T && ptoas --pto-arch=a3 --pto-backend=vpto %s -o %t --mlir-print-ir-after=convert-func-to-llvm 2>&1 || true ) | FileCheck %s

module attributes {pto.target_arch = "a3", pto.kernel_kind = #pto.kernel_kind<vector>} {

  func.func @set_mask_full() attributes {pto.aicore} {
    %cNeg1 = arith.constant -1 : i64
    pto.ub.set_mask %cNeg1, %cNeg1 : i64, i64
    return
  }

  func.func @set_mask_tail() attributes {pto.aicore} {
    %c16 = arith.constant 16 : i64
    %c0 = arith.constant 0 : i64
    pto.ub.set_mask %c0, %c16 : i64, i64
    return
  }
}

// CHECK-LABEL: llvm.func @set_mask_full_mix_aiv
// Two MOVEMASK calls per set_mask: index 0 then index 1
// CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, {{%.*}}) : (i64, i64) -> ()
// CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, {{%.*}}) : (i64, i64) -> ()

// CHECK-LABEL: llvm.func @set_mask_tail_mix_aiv
// CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, {{%.*}}) : (i64, i64) -> ()
// CHECK: llvm.call @llvm.hivm.MOVEMASK({{%.*}}, {{%.*}}) : (i64, i64) -> ()
