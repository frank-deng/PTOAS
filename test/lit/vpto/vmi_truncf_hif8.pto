// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>/dev/null | FileCheck %s

// CHECK-LABEL: func.func @vmi_truncf_hif8_default_kernel
// CHECK: pto.vcvt {{.*}} {part = "P0", rnd = "A", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P1", rnd = "A", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P2", rnd = "A", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P3", rnd = "A", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK-NOT: dist = "PK4_B32"
// CHECK: pto.vsts {{.*}} : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>
// CHECK-LABEL: func.func @vmi_truncf_hif8_hybrid_kernel
// CHECK: pto.vcvt {{.*}} {part = "P0", rnd = "H", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P1", rnd = "H", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P2", rnd = "H", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vcvt {{.*}} {part = "P3", rnd = "H", sat = "SAT"} : !pto.vreg<64xf32>, !pto.mask<b32> -> !pto.vreg<256x!pto.hif8>
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK: pto.vor
// CHECK-NOT: dist = "PK4_B32"
// CHECK: pto.vsts {{.*}} : !pto.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.mask<b8>

module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_truncf_hif8_default_kernel(%src_gm: !pto.ptr<f32, gm>,
                                            %dst_gm: !pto.ptr<!pto.hif8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c256_i64 = arith.constant 256 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c512_i64 = arith.constant 512 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_dst = pto.castptr %c512_i64 : i64 -> !pto.ptr<!pto.hif8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %x = pto.vmi.load %ub_src[%c0]
          : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
      %h = pto.vmi.truncf %x {saturate = "SAT"}
          : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256x!pto.hif8>
      pto.vmi.store %h, %ub_dst[%c0]
          : !pto.vmi.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_dst, %dst_gm, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<!pto.hif8, ub>, !pto.ptr<!pto.hif8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }

  func.func @vmi_truncf_hif8_hybrid_kernel(%src_gm: !pto.ptr<f32, gm>,
                                           %dst_gm: !pto.ptr<!pto.hif8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c256_i64 = arith.constant 256 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c512_i64 = arith.constant 512 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_dst = pto.castptr %c512_i64 : i64 -> !pto.ptr<!pto.hif8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %x = pto.vmi.load %ub_src[%c0]
          : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
      %h = pto.vmi.truncf %x {rounding = "H", saturate = "SAT"}
          : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256x!pto.hif8>
      pto.vmi.store %h, %ub_dst[%c0]
          : !pto.vmi.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_dst, %dst_gm, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<!pto.hif8, ub>, !pto.ptr<!pto.hif8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
