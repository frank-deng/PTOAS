// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --enable-vmi --emit-vpto %s -o /dev/null --mlir-print-ir-after=pto-expand-tile-op --mlir-print-ir-after=vmi-to-vpto 2>&1 | FileCheck %s

// CHECK: IR Dump After ExpandTileOp
// CHECK: IR Dump After VMIToVPTO

module {
  func.func @vpto_pipeline_vmi_after_tileop_expand() {
    %src = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %scalar = arith.constant 1.0 : f32

    pto.tadds
      ins(%src, %scalar
          : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16,
                          v_col=64, blayout=row_major, slayout=none_box,
                          fractal=512, pad=0>,
            f32)
      outs(%dst
           : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16,
                           v_col=64, blayout=row_major, slayout=none_box,
                           fractal=512, pad=0>)
    return
  }
}
