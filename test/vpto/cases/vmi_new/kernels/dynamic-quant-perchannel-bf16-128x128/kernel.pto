module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_dynamic_quant_perchannel_bf16_128x128_kernel(
      %src_gm: !pto.ptr<bf16, gm>, %scale_gm: !pto.ptr<f32, gm>,
      %out_gm: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %c8 = arith.constant 8 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    %c256 = arith.constant 256 : index
    %c0_i32 = arith.constant 0 : i32
    %c7_i32 = arith.constant 7 : i32
    %c127_i32 = arith.constant 127 : i32
    %c8_i32 = arith.constant 8 : i32
    %c128_i32 = arith.constant 128 : i32
    %c256_i32 = arith.constant 256 : i32
    %c0_f32 = arith.constant 0.000000e+00 : f32
    %c-128_f32 = arith.constant -1.280000e+02 : f32
    %c127_f32 = arith.constant 1.270000e+02 : f32
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c512_i64 = arith.constant 512 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c32768_i64 = arith.constant 32768 : i64
    %c98304_i64 = arith.constant 98304 : i64
    %c102400_i64 = arith.constant 102400 : i64
    %c106496_i64 = arith.constant 106496 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, ub>
    %ub_scratch = pto.castptr %c32768_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_scale_padded = pto.castptr %c98304_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_scale = pto.castptr %c102400_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_out = pto.castptr %c106496_i64 : i64 -> !pto.ptr<ui8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c32768_i64
      nburst(%c1_i64, %c32768_i64, %c32768_i64)
      : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      scf.for %row = %c0 to %c128 step %c1 {
        %elem_offset = arith.muli %row, %c128 : index
        %x_bf16 = pto.vmi.vload %ub_src[%elem_offset]
            : !pto.ptr<bf16, ub> -> !pto.vmi.vreg<128xbf16>
        %x_f32 = pto.vmi.vcvt %x_bf16
            : !pto.vmi.vreg<128xbf16> -> !pto.vmi.vreg<128xf32>
        pto.vmi.vstore %x_f32, %ub_scratch[%elem_offset]
            : !pto.vmi.vreg<128xf32>, !pto.ptr<f32, ub>
      }

      scf.for %col = %c0 to %c128 step %c1 {
        %col_i32 = arith.index_cast %col : index to i32
        %mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<128xpred>
        %zero = pto.vmi.vbrc %c0_f32
            : f32 -> !pto.vmi.vreg<128xf32>
        %init = pto.vmi.vbrc %c0_f32
            : f32 -> !pto.vmi.vreg<1xf32>
        %lane = pto.vmi.vci %c0_i32
            : i32 -> !pto.vmi.vreg<128xi32>
        %stride = pto.vmi.vbrc %c128_i32
            : i32 -> !pto.vmi.vreg<128xi32>
        %row_offsets = pto.vmi.vmul %lane, %stride
            : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
            -> !pto.vmi.vreg<128xi32>
        %col_vec = pto.vmi.vbrc %col_i32
            : i32 -> !pto.vmi.vreg<128xi32>
        %indices = pto.vmi.vadd %row_offsets, %col_vec
            : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
            -> !pto.vmi.vreg<128xi32>
        %col_values = pto.vmi.vgather %ub_scratch, %indices, %mask
            : !pto.ptr<f32, ub>, !pto.vmi.vreg<128xi32>,
              !pto.vmi.mask<128xpred>
            -> !pto.vmi.vreg<128xf32>
        %abs = pto.vmi.vabs %col_values
            : !pto.vmi.vreg<128xf32> -> !pto.vmi.vreg<128xf32>
        %amax = pto.vmi.vcmax %abs, %mask
            : !pto.vmi.vreg<128xf32>,
              !pto.vmi.mask<128xpred> -> !pto.vmi.vreg<1xf32>
        %max_int8 = pto.vmi.vbrc %c127_f32
            : f32 -> !pto.vmi.vreg<1xf32>
        %scale = pto.vmi.vdiv %amax, %max_int8
            : !pto.vmi.vreg<1xf32>, !pto.vmi.vreg<1xf32>
            -> !pto.vmi.vreg<1xf32>
        %padded_col = arith.muli %col, %c8 : index
        pto.vmi.vstore %scale, %ub_scale_padded[%padded_col]
            : !pto.vmi.vreg<1xf32>, !pto.ptr<f32, ub>
      }

      %scale_mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<128xpred>
      %scale_zero = pto.vmi.vbrc %c0_f32
          : f32 -> !pto.vmi.vreg<128xf32>
      %scale_lane = pto.vmi.vci %c0_i32
          : i32 -> !pto.vmi.vreg<128xi32>
      %scale_stride = pto.vmi.vbrc %c8_i32
          : i32 -> !pto.vmi.vreg<128xi32>
      %scale_indices = pto.vmi.vmul %scale_lane, %scale_stride
          : !pto.vmi.vreg<128xi32>, !pto.vmi.vreg<128xi32>
          -> !pto.vmi.vreg<128xi32>
      %scale_dense = pto.vmi.vgather %ub_scale_padded, %scale_indices, %scale_mask
          : !pto.ptr<f32, ub>, !pto.vmi.vreg<128xi32>,
            !pto.vmi.mask<128xpred>
          -> !pto.vmi.vreg<128xf32>
      pto.vmi.vstore %scale_dense, %ub_scale[%c0]
          : !pto.vmi.vreg<128xf32>, !pto.ptr<f32, ub>

      %scale_pair_mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
      %scale_pair_zero = pto.vmi.vbrc %c0_f32
          : f32 -> !pto.vmi.vreg<256xf32>
      %scale_pair_lane = pto.vmi.vci %c0_i32
          : i32 -> !pto.vmi.vreg<256xi32>
      %scale_pair_group_mask = pto.vmi.vbrc %c127_i32
          : i32 -> !pto.vmi.vreg<256xi32>
      %scale_pair_col = pto.vmi.vand %scale_pair_lane, %scale_pair_group_mask
          : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
          -> !pto.vmi.vreg<256xi32>
      %scale_pair_stride = pto.vmi.vbrc %c8_i32
          : i32 -> !pto.vmi.vreg<256xi32>
      %scale_pair_indices = pto.vmi.vmul %scale_pair_col, %scale_pair_stride
          : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
          -> !pto.vmi.vreg<256xi32>
      %scale_vec = pto.vmi.vgather %ub_scale_padded, %scale_pair_indices, %scale_pair_mask
          : !pto.ptr<f32, ub>, !pto.vmi.vreg<256xi32>,
            !pto.vmi.mask<256xpred>
          -> !pto.vmi.vreg<256xf32>
      scf.for %pair = %c0 to %c64 step %c1 {
        %row = arith.muli %pair, %c2 : index
        %elem_offset = arith.muli %row, %c128 : index
        %x = pto.vmi.vload %ub_scratch[%elem_offset]
            : !pto.ptr<f32, ub> -> !pto.vmi.vreg<256xf32>
        %scaled = pto.vmi.vdiv %x, %scale_vec
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %lo = pto.vmi.vbrc %c-128_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %hi = pto.vmi.vbrc %c127_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %clamped_lo = pto.vmi.vmax %scaled, %lo
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %clamped = pto.vmi.vmin %clamped_lo, %hi
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %i32 = pto.vmi.vcvt %clamped
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xi32>
        %zero_i32 = pto.vmi.vbrc %c0_i32
            : i32 -> !pto.vmi.vreg<256xi32>
        %byte_bias = pto.vmi.vbrc %c256_i32
            : i32 -> !pto.vmi.vreg<256xi32>
        %cmp_seed = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
        %neg = pto.vmi.vcmp %i32, %zero_i32, %cmp_seed {cmp = "slt"} : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>, !pto.vmi.mask<256xpred> -> !pto.vmi.mask<256xpred>
        %wrapped = pto.vmi.vadd %i32, %byte_bias
            : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
            -> !pto.vmi.vreg<256xi32>
        %byte_i32 = pto.vmi.vsel %neg, %wrapped, %i32
            : !pto.vmi.mask<256xpred>, !pto.vmi.vreg<256xi32>,
              !pto.vmi.vreg<256xi32>
            -> !pto.vmi.vreg<256xi32>
        %u8 = pto.vmi.vcvt %byte_i32
            : !pto.vmi.vreg<256xi32> -> !pto.vmi.vreg<256xui8>
        pto.vmi.vstore %u8, %ub_out[%elem_offset]
            : !pto.vmi.vreg<256xui8>, !pto.ptr<ui8, ub>
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_scale, %scale_gm, %c512_i64
      nburst(%c1_i64, %c512_i64, %c512_i64)
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_out, %out_gm, %c16384_i64
      nburst(%c1_i64, %c16384_i64, %c16384_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
