module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_dynamic_quant_pertoken_bf16_4x32_kernel(%src_gm: !pto.ptr<bf16, gm>,
                                                         %scale_gm: !pto.ptr<f32, gm>,
                                                         %out_gm: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c128 = arith.constant 128 : index
    %c256 = arith.constant 256 : index
    %c0_i32 = arith.constant 0 : i32
    %c256_i32 = arith.constant 256 : i32
    %c1_bf16 = arith.constant 1.000000e+00 : bf16
    %c-128_f32 = arith.constant -1.280000e+02 : f32
    %c127_f32 = arith.constant 1.270000e+02 : f32
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<bf16, ub>
    %ub_scale = pto.castptr %c1024_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_out = pto.castptr %c2048_i64 : i64 -> !pto.ptr<ui8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<bf16, gm>, !pto.ptr<bf16, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %pad_bf16 = pto.vmi.vbrc %c1_bf16
          : bf16 -> !pto.vmi.vreg<256xbf16>
      pto.vmi.vstore %pad_bf16, %ub_src[%c128]
          : !pto.vmi.vreg<256xbf16>, !pto.ptr<bf16, ub>
      pto.mem_bar "VST_VLD"
      %mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
      %x_bf16 = pto.vmi.vload %ub_src[%c0]
          : !pto.ptr<bf16, ub> -> !pto.vmi.vreg<256xbf16>
      %x = pto.vmi.vcvt %x_bf16
          : !pto.vmi.vreg<256xbf16> -> !pto.vmi.vreg<256xf32>
      %abs = pto.vmi.vabs %x
          : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf32>
      %amax = pto.vmi.vcmax %abs, %mask {group = 8}
          : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
          -> !pto.vmi.vreg<8xf32>
      %max_int8 = pto.vmi.vbrc %c127_f32
          : f32 -> !pto.vmi.vreg<8xf32>
      %scale = pto.vmi.vdiv %amax, %max_int8
          : !pto.vmi.vreg<8xf32>, !pto.vmi.vreg<8xf32>
          -> !pto.vmi.vreg<8xf32>
      pto.vmi.vstore %scale, %ub_scale[%c0], %c1 {group = 8}
          : !pto.vmi.vreg<8xf32>, !pto.ptr<f32, ub>
      %scale_vec = pto.vmi.vbrc %scale {group = 8}
          : !pto.vmi.vreg<8xf32> -> !pto.vmi.vreg<256xf32>
      %scaled = pto.vmi.vdiv %x, %scale_vec
          : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
          -> !pto.vmi.vreg<256xf32>
      %lo = pto.vmi.vbrc %c-128_f32
          : f32 -> !pto.vmi.vreg<256xf32>
      %hi = pto.vmi.vbrc %c127_f32
          : f32 -> !pto.vmi.vreg<256xf32>
      %clamped_lo = pto.vmi.vmax %scaled, %lo
          : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
          -> !pto.vmi.vreg<256xf32>
      %clamped = pto.vmi.vmin %clamped_lo, %hi
          : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
          -> !pto.vmi.vreg<256xf32>
      %i32 = pto.vmi.vcvt %clamped
          : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xi32>
      %zero_i32 = pto.vmi.vbrc %c0_i32
          : i32 -> !pto.vmi.vreg<256xi32>
      %byte_bias = pto.vmi.vbrc %c256_i32
          : i32 -> !pto.vmi.vreg<256xi32>
      %seed = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
      %neg = pto.vmi.vcmp %i32, %zero_i32, %seed {cmp = "slt"}
          : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>,
            !pto.vmi.mask<256xpred>
          -> !pto.vmi.mask<256xpred>
      %wrapped = pto.vmi.vadd %i32, %byte_bias
          : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
          -> !pto.vmi.vreg<256xi32>
      %byte_i32 = pto.vmi.vsel %neg, %wrapped, %i32
          : !pto.vmi.mask<256xpred>, !pto.vmi.vreg<256xi32>,
            !pto.vmi.vreg<256xi32>
          -> !pto.vmi.vreg<256xi32>
      %u8 = pto.vmi.vcvt %byte_i32
          : !pto.vmi.vreg<256xi32> -> !pto.vmi.vreg<256xui8>
      pto.vmi.vstore %u8, %ub_out[%c0]
          : !pto.vmi.vreg<256xui8>, !pto.ptr<ui8, ub>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_scale, %scale_gm, %c16_i64
      nburst(%c1_i64, %c16_i64, %c16_i64)
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_out, %out_gm, %c128_i64
      nburst(%c1_i64, %c128_i64, %c128_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
