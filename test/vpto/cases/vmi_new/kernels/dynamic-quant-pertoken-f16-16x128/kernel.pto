module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_dynamic_quant_pertoken_f16_16x128_kernel(%src_gm: !pto.ptr<f16, gm>,
                                                          %scale_gm: !pto.ptr<f32, gm>,
                                                          %out_gm: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %c8 = arith.constant 8 : index
    %c128 = arith.constant 128 : index
    %c256 = arith.constant 256 : index
    %c0_i32 = arith.constant 0 : i32
    %c256_i32 = arith.constant 256 : i32
    %c0_f32 = arith.constant 0.000000e+00 : f32
    %c-128_f32 = arith.constant -1.280000e+02 : f32
    %c127_f32 = arith.constant 1.270000e+02 : f32
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c64_i64 = arith.constant 64 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, ub>
    %ub_scale = pto.castptr %c4096_i64 : i64 -> !pto.ptr<f32, ub>
    %ub_out = pto.castptr %c8192_i64 : i64 -> !pto.ptr<ui8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c4096_i64
      nburst(%c1_i64, %c4096_i64, %c4096_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %scale_gm, %ub_scale, %c0_i64, %c64_i64
      nburst(%c1_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f32, gm>, !pto.ptr<f32, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %out_gm, %ub_out, %c0_i64, %c2048_i64
      nburst(%c1_i64, %c2048_i64, %c2048_i64)
      : !pto.ptr<ui8, gm>, !pto.ptr<ui8, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      scf.for %tile = %c0 to %c8 step %c1 {
        %row = arith.muli %tile, %c2 : index
        %elem_offset = arith.muli %row, %c128 : index
        %mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
        %x_f16 = pto.vmi.vload %ub_src[%elem_offset]
            : !pto.ptr<f16, ub> -> !pto.vmi.vreg<256xf16>
        %x = pto.vmi.vcvt %x_f16
            : !pto.vmi.vreg<256xf16> -> !pto.vmi.vreg<256xf32>
        %abs = pto.vmi.vabs %x
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf32>
        %amax = pto.vmi.vcmax %abs, %mask {group = 2}
            : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
            -> !pto.vmi.vreg<2xf32>
        %max_int8 = pto.vmi.vbrc %c127_f32
            : f32 -> !pto.vmi.vreg<2xf32>
        %scale = pto.vmi.vdiv %amax, %max_int8
            : !pto.vmi.vreg<2xf32>, !pto.vmi.vreg<2xf32>
            -> !pto.vmi.vreg<2xf32>
        pto.vmi.vstore %scale, %ub_scale[%row], %c1 {group = 2}
            : !pto.vmi.vreg<2xf32>, !pto.ptr<f32, ub>
        %scale_vec = pto.vmi.vbrc %scale {group = 2}
            : !pto.vmi.vreg<2xf32> -> !pto.vmi.vreg<256xf32>
        %scaled = pto.vmi.vdiv %x, %scale_vec
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %lo = pto.vmi.vbrc %c-128_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %hi = pto.vmi.vbrc %c127_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %clamped_lo = pto.vmi.vmax %scaled, %lo
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %clamped = pto.vmi.vmin %clamped_lo, %hi
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %i32 = pto.vmi.vcvt %clamped
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xi32>
        %zero_i32 = pto.vmi.vbrc %c0_i32
            : i32 -> !pto.vmi.vreg<256xi32>
        %byte_bias = pto.vmi.vbrc %c256_i32
            : i32 -> !pto.vmi.vreg<256xi32>
        %cmp_seed = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
        %neg = pto.vmi.vcmp %i32, %zero_i32, %cmp_seed {cmp = "slt"}
            : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>,
              !pto.vmi.mask<256xpred>
            -> !pto.vmi.mask<256xpred>
        %wrapped = pto.vmi.vadd %i32, %byte_bias
            : !pto.vmi.vreg<256xi32>, !pto.vmi.vreg<256xi32>
            -> !pto.vmi.vreg<256xi32>
        %byte_i32 = pto.vmi.vsel %neg, %wrapped, %i32
            : !pto.vmi.mask<256xpred>, !pto.vmi.vreg<256xi32>,
              !pto.vmi.vreg<256xi32>
            -> !pto.vmi.vreg<256xi32>
        %u8 = pto.vmi.vcvt %byte_i32
            : !pto.vmi.vreg<256xi32> -> !pto.vmi.vreg<256xui8>
        pto.vmi.vstore %u8, %ub_out[%elem_offset]
            : !pto.vmi.vreg<256xui8>, !pto.ptr<ui8, ub>
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_scale, %scale_gm, %c64_i64
      nburst(%c1_i64, %c64_i64, %c64_i64)
      : !pto.ptr<f32, ub>, !pto.ptr<f32, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_out, %out_gm, %c2048_i64
      nburst(%c1_i64, %c2048_i64, %c2048_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
