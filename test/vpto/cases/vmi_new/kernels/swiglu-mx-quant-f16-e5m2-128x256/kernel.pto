module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_swiglu_mx_quant_f16_e5m2_128x256_kernel(%src_gm: !pto.ptr<f16, gm>,
                                                         %out_gm: !pto.ptr<ui8, gm>,
                                                         %scale_gm: !pto.ptr<ui8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c2 = arith.constant 2 : index
    %c32 = arith.constant 32 : index
    %c8 = arith.constant 8 : index
    %c64 = arith.constant 64 : index
    %c128 = arith.constant 128 : index
    %c256 = arith.constant 256 : index
    %c512 = arith.constant 512 : index
    %c32768 = arith.constant 32768 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c2_i64 = arith.constant 2 : i64
    %c4_i64 = arith.constant 4 : i64
    %c8_i64 = arith.constant 8 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64
    %c128_i64 = arith.constant 128 : i64
    %c256_i64 = arith.constant 256 : i64
    %c512_i64 = arith.constant 512 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64
    %c8192_i64 = arith.constant 8192 : i64
    %c16384_i64 = arith.constant 16384 : i64
    %c32768_i64 = arith.constant 32768 : i64
    %c49152_i64 = arith.constant 49152 : i64
    %c53248_i64 = arith.constant 53248 : i64
    %c65536_i64 = arith.constant 65536 : i64
    %c98304_i64 = arith.constant 98304 : i64
    %c131072_i64 = arith.constant 131072 : i64
    %c163840_i64 = arith.constant 163840 : i64
    %c2139095040_i32 = arith.constant 2139095040 : i32
    %c23_i32 = arith.constant 23 : i32
    %c15_i32 = arith.constant 15 : i32
    %c127_i32 = arith.constant 127 : i32
    %c254_i32 = arith.constant 254 : i32
    %c0_f16 = arith.constant 0.000000e+00 : f16
    %c0_f32 = arith.constant 0.000000e+00 : f32
    %c1_f32 = arith.constant 1.000000e+00 : f32

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, ub>
    %ub_out_u8 = pto.castptr %c131072_i64 : i64 -> !pto.ptr<ui8, ub>
    %ub_out_f8 = pto.castptr %c131072_i64 : i64 -> !pto.ptr<f8E5M2, ub>
    %ub_scale = pto.castptr %c163840_i64 : i64 -> !pto.ptr<ui8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c65536_i64
      nburst(%c1_i64, %c65536_i64, %c65536_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %zero_pad = pto.vmi.vbrc %c0_f16
          : f16 -> !pto.vmi.vreg<256xf16>
      pto.vmi.vstore %zero_pad, %ub_src[%c32768]
          : !pto.vmi.vreg<256xf16>, !pto.ptr<f16, ub>
      scf.for %row = %c0 to %c128 step %c1 {
        %src_row_off = arith.muli %row, %c256 : index
        %x1_off = arith.addi %src_row_off, %c128 : index
        %out_off = arith.muli %row, %c256 : index
        %mask = pto.vmi.pset "PAT_ALL" : !pto.vmi.mask<256xpred>
        %x2_f16 = pto.vmi.vload %ub_src[%src_row_off]
            : !pto.ptr<f16, ub> -> !pto.vmi.vreg<256xf16>
        %x1_f16 = pto.vmi.vload %ub_src[%x1_off]
            : !pto.ptr<f16, ub> -> !pto.vmi.vreg<256xf16>
        %x2 = pto.vmi.vcvt %x2_f16
            : !pto.vmi.vreg<256xf16> -> !pto.vmi.vreg<256xf32>
        %x1 = pto.vmi.vcvt %x1_f16
            : !pto.vmi.vreg<256xf16> -> !pto.vmi.vreg<256xf32>
        %zero = pto.vmi.vbrc %c0_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %neg_x1 = pto.vmi.vsub %zero, %x1
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %exp_neg = pto.vmi.vexp %neg_x1
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf32>
        %one = pto.vmi.vbrc %c1_f32
            : f32 -> !pto.vmi.vreg<256xf32>
        %den = pto.vmi.vadd %one, %exp_neg
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %silu_x1 = pto.vmi.vdiv %x1, %den
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %swiglu = pto.vmi.vmul %silu_x1, %x2
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %abs = pto.vmi.vabs %swiglu
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf32>
        %amax = pto.vmi.vcmax %abs, %mask {group = 8}
            : !pto.vmi.vreg<256xf32>, !pto.vmi.mask<256xpred>
            -> !pto.vmi.vreg<8xf32>
        %amax_bits = pto.vmi.vinterpret_cast %amax
            : !pto.vmi.vreg<8xf32> -> !pto.vmi.vreg<8xi32>
        %exp_mask = pto.vmi.vbrc %c2139095040_i32
            : i32 -> !pto.vmi.vreg<8xi32>
        %shift = pto.vmi.vbrc %c23_i32
            : i32 -> !pto.vmi.vreg<8xi32>
        %emax = pto.vmi.vbrc %c15_i32
            : i32 -> !pto.vmi.vreg<8xi32>
        %scale_exp_bias = pto.vmi.vbrc %c254_i32
            : i32 -> !pto.vmi.vreg<8xi32>
        %exp_bits = pto.vmi.vand %amax_bits, %exp_mask
            : !pto.vmi.vreg<8xi32>, !pto.vmi.vreg<8xi32>
            -> !pto.vmi.vreg<8xi32>
        %exp = pto.vmi.vshr %exp_bits, %shift
            : !pto.vmi.vreg<8xi32>, !pto.vmi.vreg<8xi32>
            -> !pto.vmi.vreg<8xi32>
        %e8m0_i32 = pto.vmi.vsub %exp, %emax
            : !pto.vmi.vreg<8xi32>, !pto.vmi.vreg<8xi32>
            -> !pto.vmi.vreg<8xi32>
        %scale_ub_off = arith.muli %row, %c32 : index
        pto.vmi.vstore %e8m0_i32, %ub_scale[%scale_ub_off], %c1 {group = 8}
            : !pto.vmi.vreg<8xi32>, !pto.ptr<ui8, ub>
        %scale_exp = pto.vmi.vsub %scale_exp_bias, %e8m0_i32
            : !pto.vmi.vreg<8xi32>, !pto.vmi.vreg<8xi32>
            -> !pto.vmi.vreg<8xi32>
        %scale_bits = pto.vmi.vshl %scale_exp, %shift
            : !pto.vmi.vreg<8xi32>, !pto.vmi.vreg<8xi32>
            -> !pto.vmi.vreg<8xi32>
        %scale = pto.vmi.vinterpret_cast %scale_bits
            : !pto.vmi.vreg<8xi32> -> !pto.vmi.vreg<8xf32>
        %scale_vec = pto.vmi.vbrc %scale {group = 8}
            : !pto.vmi.vreg<8xf32> -> !pto.vmi.vreg<256xf32>
        %scaled = pto.vmi.vmul %swiglu, %scale_vec
            : !pto.vmi.vreg<256xf32>, !pto.vmi.vreg<256xf32>
            -> !pto.vmi.vreg<256xf32>
        %q8 = pto.vmi.vcvt %scaled
            : !pto.vmi.vreg<256xf32> -> !pto.vmi.vreg<256xf8E5M2>
        pto.vmi.vstore %q8, %ub_out_f8[%out_off]
            : !pto.vmi.vreg<256xf8E5M2>, !pto.ptr<f8E5M2, ub>
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_out_u8, %out_gm, %c128_i64
      nburst(%c128_i64, %c256_i64, %c128_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.mte_ub_gm %ub_scale, %scale_gm, %c4_i64
      nburst(%c128_i64, %c32_i64, %c4_i64)
      : !pto.ptr<ui8, ub>, !pto.ptr<ui8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
