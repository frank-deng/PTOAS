module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  func.func @vmi_quant_f16_to_hif8_tail_kernel(%src_gm: !pto.ptr<f16, gm>,
                                               %dst_gm: !pto.ptr<!pto.hif8, gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c256 = arith.constant 256 : index
    %c1024 = arith.constant 1024 : index
    %c1000 = arith.constant 1000 : index
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c2048_i64 = arith.constant 2048 : i64
    %c4096_i64 = arith.constant 4096 : i64

    %ub_src = pto.castptr %c0_i64 : i64 -> !pto.ptr<f16, ub>
    %ub_dst = pto.castptr %c4096_i64 : i64 -> !pto.ptr<!pto.hif8, ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c2048_i64
      nburst(%c1_i64, %c2048_i64, %c2048_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %dst_gm, %ub_dst, %c0_i64, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<!pto.hif8, gm>, !pto.ptr<!pto.hif8, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      // Phase 1 path: f16 -> hif8. Contract requires rnd in {A,H}; default
      // legacy TruncF lowering picks "A" for hif8 dst. sat = "SAT".
      %_:1 = scf.for %offset = %c0 to %c1024 step %c256 iter_args(%rem = %c1000) -> (index) {
        %mask = pto.vmi.create_mask %rem : index -> !pto.vmi.mask<256xpred>
        %wide = pto.vmi.vload %ub_src[%offset] : !pto.ptr<f16, ub> -> !pto.vmi.vreg<256xf16>
        %packed = pto.vmi.vcvt %wide : !pto.vmi.vreg<256xf16> -> !pto.vmi.vreg<256x!pto.hif8>
        pto.vmi.vstore %packed, %ub_dst[%offset], %mask {pmode = "merge"}
            : !pto.vmi.vreg<256x!pto.hif8>, !pto.ptr<!pto.hif8, ub>, !pto.vmi.mask<256xpred>
        %next = arith.subi %rem, %c256 : index
        scf.yield %next : index
      }
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_dst, %dst_gm, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<!pto.hif8, ub>, !pto.ptr<!pto.hif8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
