module attributes {pto.target_arch = "a5", pto.kernel_kind = #pto.kernel_kind<vector>} {
  // s32 -> s8 with saturate = "NOSAT" explicitly requested by the user.
  //
  // VPTO contract for this pair (added by the s32-to-s8 support patch):
  //   requiresRnd  = false
  //   requiresSat  = false        // <- unique in the S32 contract row
  //   requiresPart = true         // Packed4 family (factor=4)
  //
  // Physical form after VMIToVPTO (mirrors the u32->u8 Packed4 case, minus
  // the sat attr):
  //   4 x pto.vcvt {part = "P0"|"P1"|"P2"|"P3"}   // sat attr absent
  //   3 x pto.vor  merging into a single 256xsi8 vreg
  //
  // Layout: source vreg carries an explicit deinterleaved = 4 layout so the
  // kernel is hermetic w.r.t. future VMILayoutAssignment changes.
  //
  // Shape: 256 lanes of si32  ->  256 lanes of si8
  //        (256 * 4 = 1024 bytes read, 256 bytes written back)
  func.func @vmi_trunci_s32_to_s8_nosat_basic_kernel(
      %src_gm: !pto.ptr<si32, gm>,
      %dst_gm: !pto.ptr<si8,  gm>) attributes {pto.kernel} {
    %c0 = arith.constant 0 : index
    %c0_i64    = arith.constant 0    : i64
    %c1_i64    = arith.constant 1    : i64
    %c256_i64  = arith.constant 256  : i64
    %c1024_i64 = arith.constant 1024 : i64
    %c4096_i64 = arith.constant 4096 : i64

    %ub_src = pto.castptr %c0_i64    : i64 -> !pto.ptr<si32, ub>
    %ub_dst = pto.castptr %c4096_i64 : i64 -> !pto.ptr<si8,  ub>

    pto.mte_gm_ub %src_gm, %ub_src, %c0_i64, %c1024_i64
      nburst(%c1_i64, %c1024_i64, %c1024_i64)
      : !pto.ptr<si32, gm>, !pto.ptr<si32, ub>, i64, i64, i64, i64, i64
    pto.mte_gm_ub %dst_gm, %ub_dst, %c0_i64, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<si8, gm>, !pto.ptr<si8, ub>, i64, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE2", "PIPE_V", "EVENT_ID0"]

    pto.vecscope {
      %wide = pto.vmi.vload %ub_src[%c0]
          : !pto.ptr<si32, ub> -> !pto.vmi.vreg<256xsi32>
      // Explicit NOSAT: contract requiresSat=false -> physical vcvt drops sat.
      %narrow = pto.vmi.vcvt %wide {saturate = "NOSAT"}
          : !pto.vmi.vreg<256xsi32> -> !pto.vmi.vreg<256xsi8>
      pto.vmi.vstore %narrow, %ub_dst[%c0]
          : !pto.vmi.vreg<256xsi8>, !pto.ptr<si8, ub>
    }

    pto.set_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.wait_flag["PIPE_V", "PIPE_MTE3", "EVENT_ID0"]
    pto.mte_ub_gm %ub_dst, %dst_gm, %c256_i64
      nburst(%c1_i64, %c256_i64, %c256_i64)
      : !pto.ptr<si8, ub>, !pto.ptr<si8, gm>, i64, i64, i64, i64
    pto.barrier #pto.pipe<PIPE_ALL>
    return
  }
}
